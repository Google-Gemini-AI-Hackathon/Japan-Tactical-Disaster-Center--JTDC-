          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    Math.sin(dLon / 2) * Math.sin(dLon / 2);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  return parseFloat((R * c).toFixed(2));"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
