    replacement_infos {
      original_chunk {
        target_content: "import React, { useState, useEffect } from \"react\";\nimport { DisasterAlert, TriageStatus } from \"../types\";\nimport { Cpu, ShieldCheck, HeartPulse, Send, Copy, AlertOctagon } from \"lucide-react\";\n\ninterface TriagePanelProps {\n  activeAlert: DisasterAlert | null;\n  triageStatus: TriageStatus;\n  onTransmitBroadcast: (smsJp: string, smsEn: string) => void;\n  isTransmitting: boolean;\n}\n\nexport default function TriagePanel({\n  activeAlert,\n  triageStatus,\n  onTransmitBroadcast,\n  isTransmitting,\n}: TriagePanelProps) {\n  const [copiedJp, setCopiedJp] = useState(false);\n  const [copiedEn, setCopiedEn] = useState(false);\n  const [deployedUnitB, setDeployedUnitB] = useState(false);\n  const [gridRebalanced, setGridRebalanced] = useState(false);\n\n  // Default drafts when no active alert is present\n  const defaultAlert: DisasterAlert = {\n    disaster_type: \"other\",\n    intensity_max: \"0\",\n    epicenter: \"TOKYO-3_SECTOR_01\",\n    affected_prefectures: [],\n    immediate_hazards: [\"SYSTEM MONITORING NORMAL\"],\n    agent_triage_directives: [\"STANDBY MODE ACTIVE\"],\n    drafts: {\n      sms_alert_jp: \"\351\201\277\351\233\243\345\213\247\345\221\212\357\274\232\346\226\260\345\256\277\345\214\272\347\254\2544\343\202\273\343\202\257\343\202\277\343\203\274\343\201\256\346\226\271\343\201\257\347\233\264\343\201\241\343\201\253\346\214\207\345\256\232\343\201\256\351\201\277\351\233\243\345\240\264\346\211\200\343\201\270\347\247\273\345\213\225\343\201\227\343\201\246\343\201\217\343\201\240\343\201\225\343\201\204\343\200\202\",\n      sms_alert_en: \"EVACUATION ORDER: Sector 4 residents proceed to designated shelter.\",\n      social_feed_jp: \"\343\200\220NERV\347\201\275\345\256\263\345\257\276\347\255\226\346\234\254\351\203\250\343\200\221\347\217\276\345\234\250\345\256\211\345\256\232\347\250\274\345\203\215\344\270\255\343\200\202\346\234\211\344\272\213\343\201\256\351\232\233\343\201\257\347\233\264\343\201\241\343\201\253\350\255\246\346\210\222\343\202\242\343\203\251\343\203\274\343\203\210\343\202\222\347\231\272\345\240\261\343\201\227\343\201\276\343\201\231\343\200\202\",\n    }\n  };\n\n  const alertData = activeAlert || defaultAlert;\n\n  const handleCopy = (text: string, isJp: boolean) => {\n    navigator.clipboard.writeText(text);\n    if (isJp) {\n      setCopiedJp(true);\n      setTimeout(() => setCopiedJp(false), 2000);\n    } else {\n      setCopiedEn(true);\n      setTimeout(() => setCopiedEn(false), 2000);\n    }\n  };\n\n  return (\n    <div className=\"grid grid-rows-[auto_1fr_auto] h-full border border-[#393939] bg-[#121212] font-mono\">\n      {/* 1. Header Row */}\n      <div className=\"flex items-center gap-2 px-3 py-2 border-b border-[#393939] bg-[#0c0c0c] text-xs\">\n        <Cpu className=\"w-4 h-4 text-[#ff6600]\" />\n        <span className=\"font-bold tracking-wider text-white\">BOTTOM-RIGHT :: INTEL_TRIAGE_CORE</span>\n        <span className=\"ml-auto text-[9px] text-[#00FF66] flex items-center gap-1\">\n          <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF66] animate-pulse\"></span>\n          ACTIVE_REASONING\n        </span>\n      </div>\n\n      {/* 2. Main content split layout */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-[#393939] overflow-y-auto max-h-[600px]\">\n        \n        {/* LEFT COLUMN: Triage Engine Logs & Resource Coordinator */}\n        <div className=\"flex flex-col divide-y divide-[#393939]\">\n          \n          {/* Triage Engine Status Log */}\n          <div className=\"p-3 bg-[#080808]\">\n            <div className=\"flex justify-between items-center mb-2\">\n              <span className=\"text-[10px] text-[#00FF66] font-bold tracking-widest uppercase flex items-center gap-1\">\n                <span className=\"w-1.5 h-1.5 bg-[#00FF66] rounded-none animate-ping\"></span>\n                [TRIAGE_ENGINE]\n              </span>\n              <span className=\"text-[8px] text-gray-500 font-bold\">STATUS: PROCESSING</span>\n            </div>\n            \n            {/* Console Log readout lines */}\n            <div className=\"space-y-1 bg-[#050505] border border-[#2a2a2a] p-2 text-[9px] leading-relaxed text-gray-400 font-mono h-28 overflow-y-auto custom-scrollbar\">\n              <div className=\"text-[#00FF66]\">&gt;&gt; AGENT_GEMINI_3.5_LOADED</div>\n              <div className=\"text-gray-400 animate-pulse\">&gt;&gt; PARSING_SATELLITE_TELEMETRY...</div>\n              <div className=\"text-gray-400\">&gt;&gt; CROSS_REF_SEISMIC_DATA: MATCH_FOUND (92%)</div>\n              <div className=\"text-[#ff6600]\">&gt;&gt; INTENSITY_SHINDO: {alertData.intensity_max}</div>\n              <div className=\"text-gray-505\">&gt;&gt; OPTIMIZING_RESOURCE_FLOW_V7_ALPHA</div>\n              <div className=\"text-gray-400\">&gt;&gt; SCANNING_CRITICAL_INFRASTRUCTURE...</div>\n              {alertData.affected_prefectures.length > 0 && (\n                <div className=\"text-[#9d05ff] font-bold\">\n                  &gt;&gt; AFFECTED PREFECTURES: {alertData.affected_prefectures.join(\", \").toUpperCase()}\n                </div>\n              )}\n              {alertData.immediate_hazards.map((haz, idx) => (\n                <div key={idx} className=\"text-gray-300\">&gt;&gt; THREAT: {haz.toUpperCase()}</div>\n              ))}\n            </div>\n          </div>\n\n          {/* Resource Coordinator Actions */}\n          <div className=\"p-3 flex-1 bg-[#0c0c0c]\">\n            <span className=\"text-[10px] text-purple-400 font-bold tracking-widest block mb-2 uppercase\">\n              [RESOURCE_COORDINATOR]\n            </span>\n            <div className=\"space-y-2\">\n              \n              {/* Directive item 1: Deploy Medical Unit B */}\n              <div className=\"border border-[#393939] bg-black p-2 flex items-center justify-between text-[10px]\">\n                <div className=\"flex items-center gap-2\">\n                  <HeartPulse className=\"w-4 h-4 text-rose-500\" />\n                  <div>\n                    <div className=\"font-bold text-white\">DEPLOY_MEDICAL_UNIT_B</div>\n                    <div className=\"text-gray-400 text-[8px]\">PRIORITY: HIGH | ETA: 4m</div>\n                  </div>\n                </div>\n                <button\n                  onClick={() => setDeployedUnitB(true)}\n                  disabled={deployedUnitB}\n                  className={`px-2 py-1 text-[8px] border font-bold ${deployedUnitB ? \"border-gray-700 bg-gray-800 text-gray-500 cursor-not-allowed\" : \"border-rose-500 text-rose-500 hover:bg-rose-500/10 active:bg-rose-500/30\"}`}\n                >\n                  {deployedUnitB ? \"DEPLOYED\" : \"LAUNCH\"}\n                </button>\n              </div>\n\n              {/* Directive item 2: Rebalance Grid */}\n              <div className=\"border border-[#393939] bg-black p-2 flex items-center justify-between text-[10px]\">\n                <div className=\"flex items-center gap-2\">\n                  <ShieldCheck className=\"w-4 h-4 text-[#00e55b]\" />\n                  <div>\n                    <div className=\"font-bold text-white\">REBALANCE_GRID_P7</div>\n                    <div className=\"text-gray-400 text-[8px]\">PRIORITY: MED | READY</div>\n                  </div>\n                </div>\n                <button\n                  onClick={() => setGridRebalanced(true)}\n                  disabled={gridRebalanced}\n                  className={`px-2 py-1 text-[8px] border font-bold ${gridRebalanced ? \"border-gray-700 bg-gray-800 text-gray-500 cursor-not-allowed\" : \"border-[#00e55b] text-[#00e55b] hover:bg-[#00e55b]/10 active:bg-[#00e55b]/30\"}`}\n                >\n                  {gridRebalanced ? \"BALANCED\" : \"EXECUTE\"}\n                </button>\n              </div>\n\n              {/* Dynamic Directive Alerts from Gemini */}\n              {alertData.agent_triage_directives.slice(0, 2).map((dir, idx) => (\n                <div key={idx} className=\"border border-[#ff6600]/30 bg-black p-2 flex items-start gap-2 text-[8px] text-gray-300\">\n                  <AlertOctagon className=\"w-3.5 h-3.5 text-[#ff6600] shrink-0 mt-0.5\" />\n                  <div>\n                    <span className=\"font-bold text-[#ff6600]\">COORD_ALERT_{idx + 1}</span>\n                    <p className=\"mt-0.5\">{dir.replace(/^>>\\s*/, \"\")}</p>\n                  </div>\n                </div>\n              ))}\n\n            </div>\n          </div>\n\n        </div>\n\n        {/* RIGHT COLUMN: Public Broadcaster */}\n        <div className=\"p-3 bg-[#0d0d0d] flex flex-col justify-between\">\n          <div>\n            <div className=\"flex justify-between items-center mb-2\">\n              <span className=\"text-[10px] text-[#ff6600] font-bold tracking-widest uppercase\">\n                [PUBLIC_BROADCASTER]\n              </span>\n              <span className=\"text-[8px] text-gray-500 font-bold\">MODE: J-ALERT SYSTEM</span>\n            </div>\n\n            {/* JP translation Box */}\n            <div className=\"space-y-1 mb-3\">\n              <div className=\"flex items-center justify-between text-[8px] text-gray-400\">\n                <span>DRAFT_MSG (JP)</span>\n                <button \n                  onClick={() => handleCopy(alertData.drafts.sms_alert_jp, true)}\n                  className=\"flex items-center gap-1 hover:text-white\"\n                >\n                  <Copy className=\"w-2.5 h-2.5\" />\n                  <span>{copiedJp ? \"COPIED\" : \"COPY\"}</span>\n                </button>\n              </div>\n              <textarea\n                readOnly\n                value={alertData.drafts.sms_alert_jp}\n                className=\"w-full bg-[#050505] border border-[#2a2a2a] text-xs p-2 text-[#ff8533] focus:outline-none resize-none h-14\"\n              />\n            </div>\n\n            {/* EN translation Box */}\n            <div className=\"space-y-1\">\n              <div className=\"flex items-center justify-between text-[8px] text-gray-400\">\n                <span>DRAFT_MSG (EN)</span>\n                <button \n                  onClick={() => handleCopy(alertData.drafts.sms_alert_en, false)}\n                  className=\"flex items-center gap-1 hover:text-white\"\n                >\n                  <Copy className=\"w-2.5 h-2.5\" />\n                  <span>{copiedEn ? \"COPIED\" : \"COPY\"}</span>\n                </button>\n              </div>\n              <textarea\n                readOnly\n                value={alertData.drafts.sms_alert_en}\n                className=\"w-full bg-[#050505] border border-[#2a2a2a] text-xs p-2 text-white/90 focus:outline-none resize-none h-14\"\n              />\n            </div>\n          </div>\n\n          {/* Glowing transmitter orange button */}\n          <button\n            onClick={() => onTransmitBroadcast(alertData.drafts.sms_alert_jp, alertData.drafts.sms_alert_en)}\n            disabled={isTransmitting}\n            className=\"w-full py-2.5 mt-4 bg-[#ff6600] text-black font-extrabold tracking-widest text-[11px] hover:bg-[#ff8533] hover:shadow-[0_0_15px_rgba(255,102,0,0.6)] active:bg-[#cc5200] transition-all cursor-pointer flex items-center justify-center gap-2\"\n          >\n            <Send className=\"w-4 h-4\" />\n            {isTransmitting ? \"TRANSMITTING TO ALL SECTORS...\" : \"TRANSMIT TO ALL CHANNELS\"}\n          </button>\n        </div>\n\n      </div>\n\n      {/* 3. Footer status line */}\n      <div className=\"px-3 py-1.5 border-t border-[#393939] bg-[#0c0c0c] text-[8px] text-gray-500\">\n        TRIAGE ENGINE DEPLOYED :: COGNITIVE_MODEL: GEMINI-3.5-FLASH\n      </div>\n    </div>\n  );\n}"
        replacement_content: "import React, { useState, useEffect } from \"react\";\nimport { DisasterAlert, TriageStatus } from \"../types\";\nimport { Cpu, ShieldCheck, HeartPulse, Send, Copy, AlertOctagon } from \"lucide-react\";\n\ninterface TriagePanelProps {\n  activeAlert: DisasterAlert | null;\n  triageStatus: TriageStatus;\n  onTransmitBroadcast: (smsJp: string, smsEn: string) => void;\n  isTransmitting: boolean;\n  theme?: \"dark\" | \"light\";\n}\n\nexport default function TriagePanel({\n  activeAlert,\n  triageStatus,\n  onTransmitBroadcast,\n  isTransmitting,\n  theme = \"dark\",\n}: TriagePanelProps) {\n  const [copiedJp, setCopiedJp] = useState(false);\n  const [copiedEn, setCopiedEn] = useState(false);\n  const [deployedUnitB, setDeployedUnitB] = useState(false);\n  const [gridRebalanced, setGridRebalanced] = useState(false);\n\n  const isLight = theme === \"light\";\n\n  // Default drafts when no active alert is present\n  const defaultAlert: DisasterAlert = {\n    disaster_type: \"other\",\n    intensity_max: \"0\",\n    epicenter: \"TOKYO-3_SECTOR_01\",\n    affected_prefectures: [],\n    immediate_hazards: [\"SYSTEM MONITORING NORMAL\"],\n    agent_triage_directives: [\"STANDBY MODE ACTIVE\"],\n    drafts: {\n      sms_alert_jp: \"\351\201\277\351\233\243\345\213\247\345\221\212\357\274\232\346\226\260\345\256\277\345\214\272\347\254\2544\343\202\273\343\202\257\343\202\277\343\203\274\343\201\256\346\226\271\343\201\257\347\233\264\343\201\241\343\201\253\346\214\207\345\256\232\343\201\256\351\201\277\351\233\243\345\240\264\346\211\200\343\201\270\347\247\273\345\213\225\343\201\227\343\201\246\343\201\217\343\201\240\343\201\225\343\201\204\343\200\202\",\n      sms_alert_en: \"EVACUATION ORDER: Sector 4 residents proceed to designated shelter.\",\n      social_feed_jp: \"\343\200\220JTDC\347\201\275\345\256\263\345\257\276\347\255\226\346\234\254\351\203\250\343\200\221\347\217\276\345\234\250\345\256\211\345\256\232\347\250\274\345\203\215\344\270\255\343\200\202\346\234\211\344\272\213\343\201\256\351\232\233\343\201\257\347\233\264\343\201\241\343\201\253\350\255\246\346\210\222\343\202\242\343\203\251\343\203\274\343\203\210\343\202\222\347\231\272\345\240\261\343\201\227\343\201\276\343\201\231\343\200\202\",\n    }\n  };\n\n  const alertData = activeAlert || defaultAlert;\n\n  const handleCopy = (text: string, isJp: boolean) => {\n    navigator.clipboard.writeText(text);\n    if (isJp) {\n      setCopiedJp(true);\n      setTimeout(() => setCopiedJp(false), 2000);\n    } else {\n      setCopiedEn(true);\n      setTimeout(() => setCopiedEn(false), 2000);\n    }\n  };\n\n  const borderClass = isLight ? \"border-[#ccc7b9]\" : \"border-[#393939]\";\n  const bgClass = isLight ? \"bg-white text-stone-900\" : \"bg-[#121212] text-[#e5e2e1]\";\n  const headerBgClass = isLight ? \"bg-[#eae6db]\" : \"bg-[#0c0c0c]\";\n  const subBgClass = isLight ? \"bg-stone-50\" : \"bg-[#0c0c0c]\";\n  const consoleBgClass = isLight ? \"bg-stone-100 border-stone-200\" : \"bg-[#050505] border-[#2a2a2a]\";\n  const listBorderClass = isLight ? \"border-stone-200 bg-white\" : \"border-[#393939] bg-black\";\n\n  return (\n    <div className={`grid grid-rows-[auto_1fr_auto] h-full border ${borderClass} ${bgClass} font-mono transition-colors duration-300`}>\n      {/* 1. Header Row */}\n      <div className={`flex items-center gap-2 px-3 py-2 border-b ${borderClass} ${headerBgClass} text-xs transition-colors duration-300`}>\n        <Cpu className=\"w-4 h-4 text-[#ff6600]\" />\n        <span className={`font-bold tracking-wider ${isLight ? \"text-stone-950\" : \"text-white\"}`}>INTEL_TRIAGE_REASONING_CORE</span>\n        <span className=\"ml-auto text-[9px] text-[#00FF66] flex items-center gap-1 font-bold\">\n          <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF66] animate-pulse\"></span>\n          COGNITIVE_ACTIVE\n        </span>\n      </div>\n\n      {/* 2. Main content split layout */}\n      <div className={`grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x ${borderClass} overflow-y-auto max-h-[600px]`}>\n        \n        {/* LEFT COLUMN: Triage Engine Logs & Resource Coordinator */}\n        <div className={`flex flex-col divide-y ${borderClass}`}>\n          \n          {/* Triage Engine Status Log */}\n          <div className={`p-3 ${isLight ? \"bg-stone-50\" : \"bg-[#080808]\"}`}>\n            <div className=\"flex justify-between items-center mb-2\">\n              <span className=\"text-[10px] text-[#00FF66] font-bold tracking-widest uppercase flex items-center gap-1\">\n                <span className=\"w-1.5 h-1.5 bg-[#00FF66] rounded-none animate-ping\"></span>\n                [JTDC_TRIAGE_CORE]\n              </span>\n              <span className=\"text-[8px] text-gray-500 font-bold\">MODE: PROCESSING</span>\n            </div>\n            \n            {/* Console Log readout lines */}\n            <div className={`space-y-1 ${consoleBgClass} border p-2 text-[9px] leading-relaxed ${isLight ? \"text-stone-700 font-medium\" : \"text-gray-400\"} font-mono h-28 overflow-y-auto custom-scrollbar`}>\n              <div className=\"text-[#00FF66] font-bold\">&gt;&gt; AGENT_GEMINI_3.5_LOADED</div>\n              <div className=\"text-gray-500 animate-pulse\">&gt;&gt; PARSING_SATELLITE_TELEMETRY...</div>\n              <div className=\"text-gray-500\">&gt;&gt; CROSS_REF_SEISMIC_DATA: MATCH_FOUND (95%)</div>\n              <div className=\"text-[#ff6600] font-bold\">&gt;&gt; INTENSITY_SHINDO: {alertData.intensity_max}</div>\n              <div className=\"text-gray-500\">&gt;&gt; OPTIMIZING_RESOURCE_FLOW_V7_ALPHA</div>\n              <div className=\"text-gray-500\">&gt;&gt; SCANNING_CRITICAL_INFRASTRUCTURE...</div>\n              {alertData.affected_prefectures.length > 0 && (\n                <div className=\"text-[#9d05ff] font-bold\">\n                  &gt;&gt; AFFECTED PREFECTURES: {alertData.affected_prefectures.join(\", \").toUpperCase()}\n                </div>\n              )}\n              {alertData.immediate_hazards.map((haz, idx) => (\n                <div key={idx} className=\"text-red-500 font-bold\">&gt;&gt; ALERT_HAZARD: {haz.toUpperCase()}</div>\n              ))}\n            </div>\n          </div>\n\n          {/* Resource Coordinator Actions */}\n          <div className={`p-3 flex-1 ${subBgClass} transition-colors duration-300`}>\n            <span className=\"text-[10px] text-purple-600 dark:text-purple-400 font-bold tracking-widest block mb-2 uppercase\">\n              [RESOURCE_COORDINATOR]\n            </span>\n            <div className=\"space-y-2\">\n              \n              {/* Directive item 1: Deploy Medical Unit B */}\n              <div className={`border ${borderClass} ${listBorderClass} p-2 flex items-center justify-between text-[10px]`}>\n                <div className=\"flex items-center gap-2\">\n                  <HeartPulse className=\"w-4 h-4 text-rose-500\" />\n                  <div>\n                    <div className={`font-bold ${isLight ? \"text-stone-900\" : \"text-white\"}`}>DEPLOY_MEDICAL_UNIT_B</div>\n                    <div className=\"text-gray-500 text-[8px] font-bold\">PRIORITY: HIGH | ETA: 4m</div>\n                  </div>\n                </div>\n                <button\n                  onClick={() => setDeployedUnitB(true)}\n                  disabled={deployedUnitB}\n                  className={`px-2 py-1 text-[8px] border font-bold ${deployedUnitB ? \"border-gray-300 text-gray-400 bg-gray-100 cursor-not-allowed\" : \"border-rose-500 text-rose-500 hover:bg-rose-500/10 active:bg-rose-500/30\"}`}\n                >\n                  {deployedUnitB ? \"DEPLOYED\" : \"LAUNCH\"}\n                </button>\n              </div>\n\n              {/* Directive item 2: Rebalance Grid */}\n              <div className={`border ${borderClass} ${listBorderClass} p-2 flex items-center justify-between text-[10px]`}>\n                <div className=\"flex items-center gap-2\">\n                  <ShieldCheck className=\"w-4 h-4 text-[#00e55b]\" />\n                  <div>\n                    <div className={`font-bold ${isLight ? \"text-stone-900\" : \"text-white\"}`}>REBALANCE_POWER_GRID</div>\n                    <div className=\"text-gray-500 text-[8px] font-bold\">PRIORITY: MED | READY</div>\n                  </div>\n                </div>\n                <button\n                  onClick={() => setGridRebalanced(true)}\n                  disabled={gridRebalanced}\n                  className={`px-2 py-1 text-[8px] border font-bold ${gridRebalanced ? \"border-gray-300 text-gray-400 bg-gray-100 cursor-not-allowed\" : \"border-[#00e55b] text-[#00e55b] hover:bg-[#00e55b]/10 active:bg-[#00e55b]/30\"}`}\n                >\n                  {gridRebalanced ? \"BALANCED\" : \"EXECUTE\"}\n                </button>\n              </div>\n\n              {/* Dynamic Directive Alerts from Gemini */}\n              {alertData.agent_triage_directives.slice(0, 2).map((dir, idx) => (\n                <div key={idx} className={`border ${isLight ? \"border-amber-300 bg-amber-50\" : \"border-[#ff6600]/30 bg-black\"} p-2 flex items-start gap-2 text-[8px] ${isLight ? \"text-stone-800\" : \"text-gray-300\"}`}>\n                  <AlertOctagon className=\"w-3.5 h-3.5 text-[#ff6600] shrink-0 mt-0.5\" />\n                  <div>\n                    <span className=\"font-bold text-[#ff6600]\">TRIAGE_DIRECTIVE_{idx + 1}</span>\n                    <p className=\"mt-0.5 font-medium\">{dir.replace(/^>>\\s*/, \"\")}</p>\n                  </div>\n                </div>\n              ))}\n\n            </div>\n          </div>\n\n        </div>\n\n        {/* RIGHT COLUMN: Public Broadcaster */}\n        <div className={`p-3 ${isLight ? \"bg-white\" : \"bg-[#0d0d0d]\"} flex flex-col justify-between transition-colors duration-300`}>\n          <div>\n            <div className=\"flex justify-between items-center mb-2\">\n              <span className=\"text-[10px] text-[#ff6600] font-bold tracking-widest uppercase\">\n                [J-ALERT_BROADCASTER]\n              </span>\n              <span className=\"text-[8px] text-gray-500 font-bold\">MODE: SATELLITE DISPATCH</span>\n            </div>\n\n            {/* JP translation Box */}\n            <div className=\"space-y-1 mb-3\">\n              <div className=\"flex items-center justify-between text-[8px] text-gray-500 font-bold\">\n                <span>DRAFT_MSG (JP)</span>\n                <button \n                  onClick={() => handleCopy(alertData.drafts.sms_alert_jp, true)}\n                  className={`flex items-center gap-1 ${isLight ? \"text-stone-600 hover:text-[#ff6600]\" : \"text-gray-400 hover:text-white\"}`}\n                >\n                  <Copy className=\"w-2.5 h-2.5\" />\n                  <span>{copiedJp ? \"COPIED\" : \"COPY\"}</span>\n                </button>\n              </div>\n              <textarea\n                readOnly\n                value={alertData.drafts.sms_alert_jp}\n                className={`w-full ${isLight ? \"bg-stone-50 border-stone-200 text-stone-900\" : \"bg-[#050505] border-[#2a2a2a] text-[#ff8533]\"} text-xs p-2 focus:outline-none resize-none h-14 border font-bold`}\n              />\n            </div>\n\n            {/* EN translation Box */}\n            <div className=\"space-y-1\">\n              <div className=\"flex items-center justify-between text-[8px] text-gray-500 font-bold\">\n                <span>DRAFT_MSG (EN)</span>\n                <button \n                  onClick={() => handleCopy(alertData.drafts.sms_alert_en, false)}\n                  className={`flex items-center gap-1 ${isLight ? \"text-stone-600 hover:text-[#ff6600]\" : \"text-gray-400 hover:text-white\"}`}\n                >\n                  <Copy className=\"w-2.5 h-2.5\" />\n                  <span>{copiedEn ? \"COPIED\" : \"COPY\"}</span>\n                </button>\n              </div>\n       