<span className=\"text-[8px] text-gray-500 font-bold\">STATUS: PROCESSING</span>\n            </div>\n            \n            {/* Console Log readout lines */}\n            <div className=\"space-y-1 bg-[#050505] border border-[#2a2a2a] p-2 text-[9px] leading-relaxed text-gray-400 font-mono h-28 overflow-y-auto custom-scrollbar\">\n              <div className=\"text-[#00FF66]\">&gt;&gt; AGENT_GEMINI_3.5_LOADED</div>\n              <div className=\"text-gray-400 animate-pulse\">&gt;&gt; PARSING_SATELLITE_TELEMETRY...</div>\n              <div className=\"text-gray-400\">&gt;&gt; CROSS_REF_SEISMIC_DATA: MATCH_FOUND (92%)</div>\n              <div className=\"text-[#ff6600]\">&gt;&gt; INTENSITY_SHINDO: {alertData.intensity_max}</div>\n              <div className=\"text-gray-500\">&gt;&gt; OPTIMIZING_RESOURCE_FLOW_V7_ALPHA</div>\n              <div className=\"text-gray-400\">&gt;&gt; SCANNING_CRITICAL_INFRASTRUCTURE...</div>\n              {alertData.affected_prefectures.length > 0 && (\n                <div className=\"text-[#9d05ff] font-bold\">\n                  &gt;&gt; AFFECTED PREFECTURES: {alertData.affected_prefectures.join(\", \").toUpperCase()}\n                </div>\n              )}\n              {alertData.immediate_hazards.map((haz, idx) => (\n                <div key={idx} className=\"text-gray-300\">&gt;&gt; THREAT: {haz.toUpperCase()}</div>\n              ))}\n            </div>\n          </div>\n\n          {/* Resource Coordinator Actions */}\n          <div className=\"p-3 flex-1 bg-[#0c0c0c]\">\n            <span className=\"text-[10px] text-purple-400 font-bold tracking-widest block mb-2 uppercase\">\n              [RESOURCE_COORDINATOR]\n            </span>\n            <div className=\"space-y-2\">\n              \n              {/* Directive item 1: Deploy Medical Unit B */}\n              <div className=\"border border-[#393939] bg-black p-2 flex items-center justify-between text-[10px]\">\n                <div className=\"flex items-c