        lines {
          text: "// Spatial distance calculator (Haversine formula in KM)"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "function calculateDistance(lat1: number, lon1: number, lat2: number, lon2: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const R = 6371; // Earth\'s radius in km"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const dLat = (lat2 - lat1) * Math.PI / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const dLon = (lon2 - lon1) * Math.PI / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const a ="
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
