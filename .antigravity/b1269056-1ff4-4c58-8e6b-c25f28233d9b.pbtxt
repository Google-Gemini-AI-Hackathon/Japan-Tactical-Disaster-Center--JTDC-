 to all mobile carriers, subways, and broadcast networks. Coastal gates closing immediately. Air defence sirens activated.\n              </p>\n            </div>\n            <div className=\"flex gap-4 justify-center\">\n              <button\n                onClick={toggleEvacSiren}\n                className=\"px-6 py-2 border-2 border-[#9d05ff] text-[#9d05ff] font-bold text-xs hover:bg-[#9d05ff]/10 active:bg-[#9d05ff]/30 cursor-pointer\"\n              >\n                STAND_DOWN_SIREN\n              </button>\n            </div>\n            <div className=\"diagonal-stripes-purple h-6\"></div>\n          </div>\n        </div>\n      )}\n\n      {/* HEADER SECTION */}\n      <header className=\"border-b-2 border-[#ff6600] bg-[#121212] px-4 py-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3 shrink-0\">\n        <div className=\"flex items-center gap-3\">\n          {/* NERV Styled Orange Title */}\n          <h1 className=\"text-xl md:text-2xl font-extrabold text-[#ff6600] tracking-wider uppercase font-mono flex items-center gap-2\">\n            <Shield className=\"w-6 h-6 text-[#ff6600]\" />\n            <span>NERV GEOSPATIAL COMMAND CENTER</span>\n          </h1>\n          <span className=\"text-[10px] bg-[#ff6600]/20 text-[#ff6600] px-2 py-0.5 border border-[#ff6600] font-bold animate-pulse tracking-widest shrink-0\">\n            LIVE_STREAM\n          </span>\n        </div>\n\n        {/* Header Telemetries */}\n        <div className=\"flex flex-wrap items-center gap-4 text-xs\">\n          \n          {/* Ticking Clock Readout */}\n          <div className=\"flex items-center gap-2 border border-[#393939] px-2.5 py-1 bg-black text-gray-300\">\n            <Clock className=\"w-3.5 h-3.5 text-[#ff6600]\" />\n            <span className=\"font-bold text-white tracking-widest\">\n              {currentTime.toLocaleTimeString(\"ja-JP\", { hour12: false })} UTC\n            </span>\n          </div>\n\n          {/* Location Sector Selector */}\n          <div className=\"flex items-center gap-2\">\n            <Globe className=\"w-4 h-4 text-[#ff6600]\" />\n            <select\n              value={activeSector}\n              onChange={handleSectorChange}\n              className=\"bg-black border border-[#393939] text-[#e5e2e1] text-[11px] px-2 py-1 focus:outline-none focus:border-[#ff6600] font-bold rounded-none\"\n            >\n              <option value=\"TOKYO-3_SECTOR_01\">TOKYO-3 :: SECTOR_01</option>\n              <option value=\"SHIBUYA_SECTOR_02\">SHIBUYA :: SECTOR_02</option>\n              <option value=\"SHINJUKU_SECTOR_03\">SHINJUKU :: SECTOR_03</option>\n              <option value=\"MINATO_SECTOR_04\">MINATO :: SECTOR_04</option>\n              <option value=\"UENO_SECTOR_05\">UENO :: SECTOR_05</option>\n            </select>\n          </div>\n\n          {/* System status ready dot */}\n          <div className=\"flex items-center gap-1.5 border border-[#393939] px-2.5 py-1 bg-black shrink-0\">\n            <span className={`w-2 h-2 rounded-full animate-pulse ${activeAlert ? \"bg-[#9d05ff]\" : \"bg-[#00FF66]\"}`} />\n            <span className={`text-[10px] font-bold ${activeAlert ? \"text-[#9d05ff]\" : \"text-[#00FF66]\"}`}>\n              {activeAlert ? \"THREAT ACTIVE\" : \"SYSTEM ONLINE\"}\n            </span>\n          </div>\n        </div>\n      </header>\n\n      {/* MAIN TWO-COLUMN DASHBOARD GRID */}\n      <div className=\"flex-1 grid grid-cols-1 lg:grid-cols-[240px_1fr] divide-x divide-[#ff6600]/40 overflow-hidden\">\n        \n        {/* LEFT COLUMN: Command Unit Sidebar Navigation */}\n        <aside className=\"bg-[#0c0c0c] p-4 flex flex-col justify-between divide-y divide-[#1c1b1b]\">\n          \n          {/* Navigation controls */}\n          <div className=\"space-y-4 pb-4\">\n            <div className=\"text-[10px] text-gray-500 font-bold tracking-widest uppercase\">\n              COMMAND_UNIT_01\n            </div>\n\n            <div className=\"flex flex-col gap-1.5\">\n              \n              {/* Geospatial mode */}\n              <button\n                onClick={() => setActiveTab(\"GEOSPATIAL\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"GEOSPATIAL\" ? \"bg-[#9d05ff]/10 text-[#9d05ff] border-[#9d05ff]\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}\n              >\n                <Map className=\"w-4 h-4 shrink-0\" />\n                <span>GEOSPATIAL</span>\n              </button>\n\n              {/* Intel mode */}\n              <button\n                onClick={() => setActiveTab(\"INTEL_STREAM\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"INTEL_STREAM\" ? \"bg-[#ff6600]/10 text-[#ff6600] border-[#ff6600]\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}\n              >\n                <Radio className=\"w-4 h-4 shrink-0\" />\n                <span>INTEL_STREAM</span>\n              </button>\n\n              {/* Resource selector tab */}\n              <button\n                onClick={() => setActiveTab(\"RESOURCE_LOCATOR\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"RESOURCE_LOCATOR\" ? \"bg-[#ff6600]/10 text-[#ff6600] border-[#ff6600]\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}\n              >\n                <Globe className=\"w-4 h-4 shrink-0\" />\n                <span>RESOURCE_LOCATOR</span>\n              </button>\n\n              {/* Simulation panel tab */}\n              <button\n                onClick={() => setActiveTab(\"SIMULATION\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"SIMULATION\" ? \"bg-[#00e55b]/10 text-[#00e55b] border-[#00e55b]\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}\n              >\n                <Settings className=\"w-4 h-4 shrink-0\" />\n                <span>SIMULATION</span>\n              </button>\n            </div>\n          </div>\n\n          {/* Quick Real JMA alerts toggle */}\n          <div className=\"py-4 space-y-3\">\n            <span className=\"text-[10px] text-gray-500 font-bold tracking-widest block uppercase\">\n              [LIVE_JMA_TELEM_CODE]\n            </span>\n            <button\n              onClick={loadRealEarthquakes}\n              className=\"w-full text-center py-2 bg-[#ff6600]/5 hover:bg-[#ff6600]/15 border border-[#ff6600]/30 hover:border-[#ff6600] text-[#ff6600] text-[10px] font-extrabold tracking-widest transition-all cursor-pointer uppercase\"\n            >\n              QUERY P2PQUAKE API\n            </button>\n            \n            {showRealEarthquakes && (\n              <div className=\"bg-black/90 p-2 border border-[#393939] max-h-36 overflow-y-auto text-[8px] font-mono space-y-1 custom-scrollbar text-gray-400\">\n                <div className=\"text-white border-b border-[#2a2a2a] pb-1 font-bold text-[9px]\">LATEST JMA TELEMETRY:</div>\n                {realEarthquakes.length === 0 ? (\n                  <div className=\"animate-pulse\">STREAMING DATA...</div>\n                ) : (\n                  realEarthquakes.map((eq: any, idx: number) => (\n                    <div key={idx} className=\"border-b border-[#111] pb-1 mb-1\">\n                      <div className=\"text-[#ff6600] font-bold\">EPICENTER: {eq.earthquake?.hypocenter?.name || \"Unknown\"}</div>\n                      <div>TIME: {new Date(eq.time || Date.now()).toLocaleTimeString()}</div>\n                      <div>SHINDO SC: {(eq.earthquake?.maxScale / 10) || \"N/A\"}</div>\n                    </div>\n                  ))\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* Bottom control buttons */}\n          <div className=\"pt-4 space-y-2.5\">\n            {/* Initiate Emergency Protocol Button */}\n            <button\n              onClick={toggleEvacSiren}\n              className=\"w-full py-3 bg-[#9d05ff]/20 hover:bg-[#9d05ff]/35 border-2 border-[#9d05ff] text-[#9d05ff] hover:shadow-[0_0_15px_rgba(157,0,255,0.5)] transition-all cursor-pointer text-[10px] font-extrabold tracking-widest text-center uppercase\"\n            >\n              INITIATE_EVAC_PROTOCOL\n            </button>\n\n            {activeAlert && (\n              <button\n                onClick={handleClearAlert}\n                className=\"w-full py-2 bg-gray-900/50 hover:bg-gray-800 border border-gray-700 text-gray-400 text-[9px] font-bold tracking-widest text-center uppercase\"\n              >\n                RESET_THREAT_READY\n              </button>\n            )}\n\n            <div className=\"flex items-center gap-2 pt-2 text-[9px] text-gray-500\">\n              <Power className=\"w-3 h-3 text-red-500 animate-pulse\" />\n              <span>LOGOUT_COMMANDER</span>\n            </div>\n          </div>\n        </aside>"
      replacement_content: "  const isLight = theme === \"light\";\n\n  return (\n    <div className={`min-h-screen ${isLight ? \"bg-[#fbf9f4] text-stone-900\" : \"bg-[#050505] text-[#e5e2e1]\"} flex flex-col relative select-none scanlines transition-colors duration-300`}>\n      \n      {/* FULL-SCREEN SIREN EVACUATION STROBE COVER */}\n      {isSirenActive && (\n        <div className=\"absolute inset-0 z-50 bg-[#9d05ff]/20 animate-pulse pointer-events-none mix-blend-color-burn border-8 border-[#9d05ff] flex items-center justify-center\">\n          <div className=\"bg-black/95 border-4 border-[#9d05ff] p-8 max-w-xl text-center space-y-6 pointer-events-auto shadow-[0_0_50px_rgba(157,0,255,0.8)]\">\n            <div className=\"diagonal-stripes-purple h-6\"></div>\n            <div className=\"flex justify-center gap-3\">\n              <BellRing className=\"w-12 h-12 text-[#9d05ff] animate-bounce\" />\n              <Flame className=\"w-12 h-12 text-[#ff6600] animate-pulse\" />\n            </div>\n            <div>\n              <h1 className=\"text-3xl font-extrabold text-[#9d05ff] tracking-widest uppercase blink-fast\">\n                EVACUATION PROTOCOL\n              </h1>\n              <p className=\"text-xs text-gray-400 mt-2 tracking-wider\">\n                \343\200\220\346\227\245\346\234\254\346\234\211\344\272\213\347\201\275\345\256\263\345\257\276\347\255\226\346\214\207\346\217\256\346\234\254\351\203\250\343\203\273JTDC\344\275\234\346\210\246\347\256\241\345\210\266\351\203\250\343\200\221\n              </p>\n            </div>\n            <div className=\"border border-[#9d05ff]/50 bg-black p-4 text-left text-sm space-y-3 font-mono text-[#ff8533]\">\n              <p>\342\227\217 SECTOR: <span className=\"text-white font-bold\">{activeSector}</span></p>\n              <p>\342\227\217 STATUS: <span className=\"text-red-500 blink-fast font-bold\">ALL CITIZENS PROCEED TO DESIGNATED REINFORCED SHELTERS</span></p>\n              <p className=\"text-xs text-gray-500 leading-relaxed\">\n                J-Alert has been dispatched to all mobile carriers, subways, and broadcast networks. Coastal gates closing immediately. Air defence sirens activated.\n              </p>\n            </div>\n            <div className=\"flex gap-4 justify-center\">\n              <button\n                onClick={toggleEvacSiren}\n                className=\"px-6 py-2 border-2 border-[#9d05ff] text-[#9d05ff] font-bold text-xs hover:bg-[#9d05ff]/10 active:bg-[#9d05ff]/30 cursor-pointer\"\n              >\n                STAND_DOWN_SIREN\n              </button>\n            </div>\n            <div className=\"diagonal-stripes-purple h-6\"></div>\n          </div>\n        </div>\n      )}\n\n      {/* HEADER SECTION */}\n      <header className={`border-b-2 border-[#ff6600] ${isLight ? \"bg-[#eae6db] text-stone-900\" : \"bg-[#121212] text-[#e5e2e1]\"} px-4 py-3 flex flex-col md:flex-row md:items-center md:justify-between gap-3 shrink-0 transition-colors duration-300`}>\n        <div className=\"flex items-center gap-3\">\n          {/* JTDC Styled Orange Title */}\n          <h1 className=\"text-xl md:text-2xl font-extrabold text-[#ff6600] tracking-wider uppercase font-mono flex items-center gap-2\">\n            <Shield className=\"w-6 h-6 text-[#ff6600]\" />\n            <span>JAPAN TACTICAL DISASTER CENTER (JTDC)</span>\n          </h1>\n          <span className=\"text-[10px] bg-[#ff6600]/20 text-[#ff6600] px-2 py-0.5 border border-[#ff6600] font-bold animate-pulse tracking-widest shrink-0\">\n            LIVE_STREAM\n          </span>\n        </div>\n\n        {/* Header Telemetries */}\n        <div className=\"flex flex-wrap items-center gap-4 text-xs\">\n          \n          {/* Light Mode / Dark Mode Toggle Button */}\n          <button\n            onClick={() => setTheme(isLight ? \"dark\" : \"light\")}\n            className={`flex items-center gap-1.5 px-2.5 py-1 border ${isLight ? \"border-stone-400 bg-stone-100 hover:bg-stone-200 text-stone-800\" : \"border-[#393939] bg-black hover:bg-[#121212] text-gray-300\"} font-mono font-bold text-[10px] tracking-wider uppercase transition-all cursor-pointer`}\n            title=\"Toggle Theme Mode\"\n          >\n            {isLight ? (\n              <>\n                <Moon className=\"w-3.5 h-3.5 text-purple-600\" />\n                <span>DARK_MODE</span>\n              </>\n            ) : (\n              <>\n                <Sun className=\"w-3.5 h-3.5 text-amber-500 animate-spin-slow\" />\n                <span>LIGHT_MODE</span>\n              </>\n            )}\n          </button>\n\n          {/* Ticking Clock Readout */}\n          <div className={`flex items-center gap-2 border ${isLight ? \"border-stone-400 bg-[#fbf9f4]\" : \"border-[#393939] bg-black\"} px-2.5 py-1 text-gray-300`}>\n            <Clock className=\"w-3.5 h-3.5 text-[#ff6600]\" />\n            <span className={`font-bold ${isLight ? \"text-stone-900\" : \"text-white\"} tracking-widest`}>\n              {currentTime.toLocaleTimeString(\"ja-JP\", { hour12: false })} UTC\n            </span>\n          </div>\n\n          {/* Location Sector Selector */}\n          <div className=\"flex items-center gap-2\">\n            <Globe className=\"w-4 h-4 text-[#ff6600]\" />\n            <select\n              value={activeSector}\n              onChange={handleSectorChange}\n              className={`${isLight ? \"bg-[#fbf9f4] border-stone-400 text-stone-900\" : \"bg-black border border-[#393939] text-[#e5e2e1]\"} text-[11px] px-2 py-1 focus:outline-none focus:border-[#ff6600] font-bold rounded-none`}\n            >\n              <option value=\"TOKYO-3_SECTOR_01\">TOKYO-3 :: SECTOR_01</option>\n              <option value=\"SHIBUYA_SECTOR_02\">SHIBUYA :: SECTOR_02</option>\n              <option value=\"SHINJUKU_SECTOR_03\">SHINJUKU :: SECTOR_03</option>\n              <option value=\"MINATO_SECTOR_04\">MINATO :: SECTOR_04</option>\n              <option value=\"UENO_SECTOR_05\">UENO :: SECTOR_05</option>\n            </select>\n          </div>\n\n          {/* System status ready dot */}\n          <div className={`flex items-center gap-1.5 border ${isLight ? \"border-stone-400 bg-[#fbf9f4]\" : \"border-[#393939] bg-black\"} px-2.5 py-1 shrink-0`}>\n            <span className={`w-2 h-2 rounded-full animate-pulse ${activeAlert ? \"bg-[#9d05ff]\" : \"bg-[#00FF66]\"}`} />\n            <span className={`text-[10px] font-bold ${activeAlert ? \"text-[#9d05ff]\" : \"text-[#00FF66]\"}`}>\n              {activeAlert ? \"THREAT ACTIVE\" : \"SYSTEM ONLINE\"}\n            </span>\n          </div>\n        </div>\n      </header>\n\n      {/* MAIN TWO-COLUMN DASHBOARD GRID */}\n      <div className={`flex-1 grid grid-cols-1 lg:grid-cols-[240px_1fr] divide-x ${isLight ? \"divide-stone-300 bg-[#fbf9f4]\" : \"divide-[#ff6600]/40\"} overflow-hidden`}>\n        \n        {/* LEFT COLUMN: Command Unit Sidebar Navigation */}\n        <aside className={`${isLight ? \"bg-[#eae6db] border-r border-stone-300 divide-stone-300\" : \"bg-[#0c0c0c] divide-[#1c1b1b]\"} p-4 flex flex-col justify-between divide-y transition-colors duration-300`}>\n          \n          {/* Navigation controls */}\n          <div className=\"space-y-4 pb-4\">\n            <div className=\"text-[10px] text-gray-500 font-bold tracking-widest uppercase\">\n              JTDC_COMMAND_UNIT_01\n            </div>\n\n            <div className=\"flex flex-col gap-1.5\">\n              \n              {/* Geospatial mode */}\n              <button\n                onClick={() => setActiveTab(\"GEOSPATIAL\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"GEOSPATIAL\" ? \"bg-[#9d05ff]/10 text-[#9d05ff] border-[#9d05ff]\" : `${isLight ? \"border-transparent text-stone-700 hover:text-stone-950 hover:bg-stone-100\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}`}\n              >\n                <Map className=\"w-4 h-4 shrink-0\" />\n                <span>GEOSPATIAL</span>\n              </button>\n\n              {/* Intel mode */}\n              <button\n                onClick={() => setActiveTab(\"INTEL_STREAM\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"INTEL_STREAM\" ? \"bg-[#ff6600]/10 text-[#ff6600] border-[#ff6600]\" : `${isLight ? \"border-transparent text-stone-700 hover:text-stone-950 hover:bg-stone-100\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}`}\n              >\n                <Radio className=\"w-4 h-4 shrink-0\" />\n                <span>INTEL_STREAM</span>\n              </button>\n\n              {/* Resource selector tab */}\n              <button\n                onClick={() => setActiveTab(\"RESOURCE_LOCATOR\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"RESOURCE_LOCATOR\" ? \"bg-[#ff6600]/10 text-[#ff6600] border-[#ff6600]\" : `${isLight ? \"border-transparent text-stone-700 hover:text-stone-950 hover:bg-stone-100\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}`}\n              >\n                <Globe className=\"w-4 h-4 shrink-0\" />\n                <span>RESOURCE_LOCATOR</span>\n              </button>\n\n              {/* Simulation panel tab */}\n              <button\n                onClick={() => setActiveTab(\"SIMULATION\")}\n                className={`w-full py-2.5 px-3 text-left font-bold text-xs flex items-center gap-2 border transition-all ${activeTab === \"SIMULATION\" ? \"bg-[#00e55b]/10 text-[#00e55b] border-[#00e55b]\" : `${isLight ? \"border-transparent text-stone-700 hover:text-stone-950 hover:bg-stone-100\" : \"border-[#1c1b1b] text-gray-400 hover:text-white\"}`}`}\n              >\n                <Settings className=\"w-4 h-4 shrink-0\" />\n                <span>SIMULATION</span>\n              </button>\n            </div>\n          </div>\n\n          {/* Quick Real JMA alerts toggle */}\n          <div className=\"py-4 space-y-3\">\n            <span className=\"text-[10px] text-gray-500 font-bold tracking-widest block uppercase\">\n              [LIVE_JMA_TELEM_CODE]\n            </span>\n            <button\n              onClick={loadRealEarthquakes}\n              className=\"w-full text-center py-2 bg-[#ff6600]/5 hover:bg-[#ff6600]/15 border border-[#ff6600]/30 hover:border-[#ff6600] text-[#ff6600] text-[10px] font-extrabold tracking-widest transition-all cursor-pointer uppercase\"\n            >\n              QUERY P2PQUAKE API\n            </button>\n            \n            {showRealEarthquakes && (\n              <div className={`p-2 border max-h-36 overflow-y-auto text-[8px] font-mono space-y-1 custom-scrollbar ${isLight ? \"bg-white border-stone-300 text-stone-600\" : \"bg-black/90 border-[#393939] text-gray-400\"}`}>\n                <div className={`border-b pb-1 font-bold text-[9px] ${isLight ? \"text-stone-900 border-stone-200\" : \"text-white border-[#2a2a2a]\"}`}>LATEST JMA TELEMETRY:</div>\n                {realEarthquakes.length === 0 ? (\n                  <div className=\"animate-pulse\">STREAMING DATA...</div>\n                ) : (\n                  realEarthquakes.map((eq: any, idx: number) => (\n                    <div key={idx} className={`border-b pb-1 mb-1 ${isLight ? \"border-stone-100\" : \"border-[#111]\"}`}>\n                      <div className=\"text-[#ff6600] font-bold\">EPICENTER: {eq.earthquake?.hypocenter?.name || \"Unknown\"}</div>\n                      <div>TIME: {new Date(eq.time || Date.now()).toLocaleTimeString()}</div>\n                      <div>SHINDO SC: {(eq.earthquake?.maxScale / 10) || \"N/A\"}</div>\n                    </div>\n                  ))\n                )}\n              </div>\n            )}\n          </div>\n\n          {/* Bottom control buttons */}\n          <div className=\"pt-4 space-y-2.5\">\n            {/* Initiate Emergency Protocol Button */}\n            <button\n              onClick={toggleEvacSiren}\n              className=\"w-full py-3 bg-[#9d05ff]/20 hover:bg-[#9d05ff]/35 border-2 border-[#9d05ff] text-[#9d05ff] hover:shadow-[0_0_15px_rgba(157,0,255,0.5)] transition-all cursor-pointer text-[10px] font-extrabold tracking-widest text-center uppercase\"\n            >\n              INITIATE_EVAC_PROTOCOL\n            </button>\n\n            {activeAlert && (\n              <button\n                onClick={handleClearAlert}\n                className={`w-full py-2 text-[9px] font-bold tracking-widest text-center uppercase border ${isLight ? \"bg-stone-100 border-stone-300 text-stone-700 hover:bg-stone-200\" : \"bg-gray-900/50 hover:bg-gray-800 border-gray-700 text-gray-400\"}`}\n              >\n                RESET_THREAT_READY\n              </button>\n            )}\n\n            <div className=\"flex items-center gap-2 pt-2 text-[9px] text-gray-500 font-bold\">\n              <Power className=\"w-3 h-3 text-red-500 animate-pulse\" />\n              <span>LOGOUT_COMMANDER</span>\n            </div>\n          </div>\n        </aside>"
    }
    replacement_chunks {
      target_content: "        {/* RIGHT COLUMN: The grand interactive cockpit grids */}\n        <main className=\"p-4 space-y-4 overflow-y-auto max-h-[calc(100vh-60px)]\">\n          \n          {/* Main layout split row (Interactive Map & Simulation Overlay on left, Intel Logs & Broadcasts on right) */}\n          <div className=\"grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-4\">\n            \n            {/* Left section: Interactive Map Canvas container */}\n            <div className=\"flex flex-col gap-4\">\n              <div className=\"h-[400px] md:h-[500px]\">\n                <TacticalMap\n                  shelters={shelters}\n                  activeAlert={activeAlert}\n                  selectedShelterId={selectedShelterId}\n                  onSelectShelter={setSelectedShelterId}\n                  satelliteImage={satelliteImage}\n                />\n              </div>\n\n              {/* Dynamic threat details panel shown if disaster active */}\n              {activeAlert && (\n                <div className=\"border border-[#9d05ff] bg-[#9d05ff]/5 p-3.5 space-y-2.5\">\n                  <div className=\"flex justify-between border-b border-[#9d05ff]/30 pb-1.5 items-center\">\n                    <span className=\"text-[#9d05ff] font-extrabold text-xs flex items-center gap-1.5 uppercase blink-fast\">\n                      <Volume2 className=\"w-4 h-4\" />\n                      [ACTIVE_DISASTER_ALERT_LEVEL_4]\n                    </span>\n                    <span className=\"text-[10px] text-gray-400 font-bold\">\n                      DETECTED: {activeAlert.timestamp || \"RECENT\"}\n                    </span>\n                  </div>\n                  <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3 text-xs leading-relaxed\">\n                    <div className=\"border border-[#393939] bg-black p-2\">\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">epicenter:</span>\n                      <span className=\"text-white font-extrabold\">{activeAlert.epicenter}</span>\n                    </div>\n                    <div className=\"border border-[#393939] bg-black p-2\">\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">intensity:</span>\n                      <span className=\"text-[#9d05ff] font-extrabold\">JMA SHINDO {activeAlert.intensity_max}</span>\n                    </div>\n                    <div className=\"border border-[#393939] bg-black p-2\">\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">hazards:</span>\n                      <span className=\"text-gray-300 font-medium truncate block\">{activeAlert.immediate_hazards[0] || \"None\"}</span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            {/* Right section: Triage reasoning core and incoming intel logs */}\n            <div className=\"grid grid-rows-[1fr_auto] gap-4\">\n              \n              {/* Top Right: Real-time Intel Streams */}\n              <div className=\"h-[300px] md:h-[350px] xl:h-full\">\n                <IntelStream\n                  feed={intelFeed}\n                  onSelectItem={(item) => {\n                    const logItem: IntelItem = {\n                      id: `intel_${Date.now()}`,\n                      time: new Date().toLocaleTimeString(\"ja-JP\", { hour12: false }),\n                      tag: \"NERV\",\n                      text: `INSPECTING LOG DETAIL: \"${item.text}\"`,\n                    };\n                    setIntelFeed((prev) => [...prev, logItem]);\n                  }}\n                />\n              </div>\n\n              {/* Bottom Right: Gemini Triage & broadast channels */}\n              <div className=\"h-auto\">\n                <TriagePanel\n                  activeAlert={activeAlert}\n                  triageStatus={triageStatus}\n                  onTransmitBroadcast={handleTransmitBroadcast}\n                  isTransmitting={isBroadcasting}\n                />\n              </div>\n\n            </div>\n\n          </div>\n\n          {/* Sandbox control block for triggering simulations */}\n          <div className=\"border-t border-[#ff6600]/10 pt-1\">\n            <SimulationControls\n              onTriggerEarthquake={triggerSimulationEarthquake}\n              onRunTriage={runSatelliteTriage}\n              isProcessing={isProcessingTriage}\n            />\n          </div>\n\n          {/* Bottom Panel: Nearest Shelters locator grid */}\n          <div className=\"border-t border-[#ff6600]/10 pt-1\">\n            <ShelterLocator\n              shelters={shelters}\n              selectedShelterId={selectedShelterId}\n              onSelectShelter={setSelectedShelterId}\n              activeHazard={activeAlert?.disaster_type || \"earthquake\"}\n            />\n          </div>\n\n        </main>\n      </div>\n\n      {/* FOOTER SYSTEM STATUS TELEMETRIES */}\n      <footer className=\"border-t-2 border-[#ff6600] bg-black text-gray-500 text-[10px] px-4 py-2 flex flex-wrap justify-between items-center gap-3 shrink-0\">\n        <div className=\"flex flex-wrap gap-x-6 gap-y-1 font-mono\">\n          <div>UPTIME: <span className=\"text-white\">1422:12:04</span></div>\n          <div>DATA_FLOW: <span className=\"text-white\">4.2 TB/S</span></div>\n          <div>NODES: <span className=\"text-[#00FF66]\">1,024 ACTIVE</span></div>\n          <div>TERMINAL_ACCESS: <span className=\"text-[#00FF66]\">SECURE</span></div>\n          <div>API_DOCS: <span className=\"text-gray-400 font-bold underline cursor-pointer\">p2pquake_v2_history</span></div>\n        </div>\n        <div className=\"text-right text-gray-600 font-mono text-[9px]\">\n          \302\251 2026 NERV STRATEGIC OPERATIONS. DATA_CONFIDENTIALITY_LEVEL_4.\n        </div>\n      </footer>"
      replacement_content: "        {/* RIGHT COLUMN: The grand interactive cockpit grids */}\n        <main className=\"p-4 space-y-4 overflow-y-auto max-h-[calc(100vh-60px)]\">\n          \n          {/* Main layout split row (Interactive Map & Simulation Overlay on left, Intel Logs & Broadcasts on right) */}\n          <div className=\"grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-4\">\n            \n            {/* Left section: Interactive Map Canvas container */}\n            <div className=\"flex flex-col gap-4\">\n              <div className=\"h-[400px] md:h-[500px]\">\n                <TacticalMap\n                  shelters={shelters}\n                  activeAlert={activeAlert}\n                  selectedShelterId={selectedShelterId}\n                  onSelectShelter={setSelectedShelterId}\n                  satelliteImage={satelliteImage}\n                  theme={theme}\n                  onMapClick={(lat, lng) => triggerSimulationEarthquake(6.8, \"Custom Epicenter\", lat, lng)}\n                />\n              </div>\n\n              {/* Dynamic threat details panel shown if disaster active */}\n              {activeAlert && (\n                <div className={`border border-[#9d05ff] bg-[#9d05ff]/5 p-3.5 space-y-2.5 ${isLight ? \"text-stone-900\" : \"text-white\"}`}>\n                  <div className=\"flex justify-between border-b border-[#9d05ff]/30 pb-1.5 items-center\">\n                    <span className=\"text-[#9d05ff] font-extrabold text-xs flex items-center gap-1.5 uppercase blink-fast\">\n                      <Volume2 className=\"w-4 h-4\" />\n                      [ACTIVE_DISASTER_ALERT_LEVEL_4]\n                    </span>\n                    <span className=\"text-[10px] text-gray-500 font-bold\">\n                      DETECTED: {activeAlert.timestamp || \"RECENT\"}\n                    </span>\n                  </div>\n                  <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3 text-xs leading-relaxed\">\n                    <div className={`border ${isLight ? \"border-stone-300 bg-white\" : \"border-[#393939] bg-black\"} p-2`}>\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">epicenter:</span>\n                      <span className={`font-extrabold ${isLight ? \"text-stone-950\" : \"text-white\"}`}>{activeAlert.epicenter}</span>\n                    </div>\n                    <div className={`border ${isLight ? \"border-stone-300 bg-white\" : \"border-[#393939] bg-black\"} p-2`}>\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">intensity:</span>\n                      <span className=\"text-[#9d05ff] font-extrabold\">JMA SHINDO {activeAlert.intensity_max}</span>\n                    </div>\n                    <div className={`border ${isLight ? \"border-stone-300 bg-white\" : \"border-[#393939] bg-black\"} p-2`}>\n                      <span className=\"text-[#ff6600] text-[9px] font-bold block uppercase\">hazards:</span>\n                      <span className={`font-medium truncate block ${isLight ? \"text-stone-700\" : \"text-gray-300\"}`}>{activeAlert.immediate_hazards[0] || \"None\"}</span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            {/* Right section: Triage reasoning core and incoming intel logs */}\n            <div className=\"grid grid-rows-[1fr_auto] gap-4\">\n              \n              {/* Top Right: Real-time Intel Streams */}\n              <div className=\"h-[300px] md:h-[350px] xl:h-full\">\n                <IntelStream\n                  feed={intelFeed}\n                  theme={theme}\n                  onSelectItem={(item) => {\n                    const logItem: IntelItem = {\n                      id: `intel_${Date.now()}`,\n                      time: new Date().toLocaleTimeString(\"ja-JP\", { hour12: false }),\n                      tag: \"NERV\",\n                      text: `INSPECTING LOG DETAIL: \"${item.text}\"`,\n                    };\n                    setIntelFeed((prev) => [...prev, logItem]);\n                  }}\n                />\n              </div>\n\n              {/* Bottom Right: Gemini Triage & broadast channels */}\n              <div className=\"h-auto\">\n                <TriagePanel\n                  activeAlert={activeAlert}\n                  triageStatus={triageStatus}\n                  onTransmitBroadcast={handleTransmitBroadcast}\n                  isTransmitting={isBroadcasting}\n                  theme={theme}\n                />\n              </div>\n\n            </div>\n\n          </div>\n\n          {/* Sandbox control block for triggering simulations */}\n          <div className=\"border-t border-[#ff6600]/10 pt-1\">\n            <SimulationControls\n              onTriggerEarthquake={triggerSimulationEarthquake}\n              onRunTriage={runSatelliteTriage}\n              isProcessing={isProcessingTriage}\n              theme={theme}\n            />\n          </div>\n\n          {/* Bottom Panel: Nearest Shelters locator grid */}\n          <div className=\"border-t border-[#ff6600]/10 pt-1\">\n            <ShelterLocator\n              shelters={shelters}\n              selectedShelterId={selectedShelterId}\n              onSelectShelter={setSelectedShelterId}\n              activeHazard={activeAlert?.disaster_type || \"earthquake\"}\n              theme={theme}\n            />\n          </div>\n\n        </main>\n      </div>\n\n      {/* FOOTER SYSTEM STATUS TELEMETRIES */}\n      <footer className={`border-t-2 border-[#ff6600] ${isLight ? \"bg-[#eae6db] text-stone-600 border-stone-300\" : \"bg-black text-gray-500\"} text-[10px] px-4 py-2 flex flex-wrap justify-between items-center gap-3 shrink-0 transition-colors duration-300`}>\n        <div className=\"flex flex-wrap gap-x-6 gap-y-1 font-mono font-bold\">\n          <div>UPTIME: <span className={isLight ? \"text-stone-900\" : \"text-white\"}>1422:12:04</span></div>\n          <div>DATA_FLOW: <span className={isLight ? \"text-stone-900\" : \"text-white\"}>4.2 TB/S</span></div>\n          <div>NODES: <span className=\"text-[#00FF66]\">1,024 ACTIVE</span></div>\n          <div>TERMINAL_ACCESS: <span className=\"text-[#00FF66]\">SECURE</span></div>\n          <div>API_DOCS: <span className={`${isLight ? \"text-stone-800\" : \"text-gray-400\"} font-bold underline cursor-pointer`}>p2pquake_v2_history</span></div>\n        </div>\n        <div className={`text-right ${isLight ? \"text-stone-500\" : \"text-gray-600\"} font-mono text-[9px] font-bold`}>\n          \302\251 2026 JAPAN TACTICAL DISASTER CENTER (JTDC). DATA_CONFIDENTIALITY_LEVEL_4.\n        </div>\n      </footer>"
    }
