  file_change {
    absolute_path_uri: "file:///src/index.css"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n  --font-mono: \"JetBrains Mono\", ui-monospace, SFMono-Regular, monospace;\n}\n\n@layer base {\n  body {\n    @apply bg-[#050505] text-[#e5e2e1] font-mono select-none antialiased;\n    font-feature-settings: \"tnum\";\n  }\n}\n\n/* Custom Scanlines & CRT Grids */\n.nerv-grid-bg {\n  background-image: \n    linear-gradient(rgba(18, 18, 18, 0.4) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(18, 18, 18, 0.4) 1px, transparent 1px);\n  background-size: 20px 20px;\n}\n\n.scanlines {\n  position: relative;\n  overflow: hidden;\n}\n\n.scanlines::before {\n  content: \" \";\n  display: block;\n  position: absolute;\n  top: 0; left: 0; bottom: 0; right: 0;\n  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));\n  z-index: 10;\n  background-size: 100% 4px, 6px 100%;\n  pointer-events: none;\n}\n\n/* Segmented block animations or glowing animations */\n@keyframes pulseGlowOrange {\n  0%, 100% {\n    box-shadow: 0 0 4px rgba(255, 102, 0, 0.2), inset 0 0 2px rgba(255, 102, 0, 0.1);\n    border-color: rgba(255, 102, 0, 0.4);\n  }\n  50% {\n    box-shadow: 0 0 12px rgba(255, 102, 0, 0.5), inset 0 0 6px rgba(255, 102, 0, 0.25);\n    border-color: rgba(255, 102, 0, 0.8);\n  }\n}\n\n@keyframes pulseGlowPurple {\n  0%, 100% {\n    box-shadow: 0 0 4px rgba(157, 0, 255, 0.2), inset 0 0 2px rgba(157, 0, 255, 0.1);\n    border-color: rgba(157, 0, 255, 0.4);\n  }\n  50% {\n    box-shadow: 0 0 12px rgba(157, 0, 255, 0.5), inset 0 0 6px rgba(157, 0, 255, 0.25);\n    border-color: rgba(157, 0, 255, 0.8);\n  }\n}\n\n@keyframes pulseGlowGreen {\n  0%, 100% {\n    box-shadow: 0 0 4px rgba(0, 255, 102, 0.15), inset 0 0 1px rgba(0, 255, 102, 0.1);\n    border-color: rgba(0, 255, 102, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 10px rgba(0, 255, 102, 0.4), inset 0 0 4px rgba(0, 255, 102, 0.2);\n    border-color: rgba(0, 255, 102, 0.7);\n  }\n}\n\n.glow-orange {\n  animation: pulseGlowOrange 3s infinite ease-in-out;\n}\n\n.glow-purple {\n  animation: pulseGlowPurple 3s infinite ease-in-out;\n}\n\n.glow-green {\n  animation: pulseGlowGreen 3s infinite ease-in-out;\n}\n\n/* Blinking animations */\n@keyframes blink {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0; }\n}\n\n.blink-fast {\n  animation: blink 0.6s infinite steps(1);\n}\n\n.blink-slow {\n  animation: blink 1.5s infinite ease-in-out;\n}\n\n/* Custom scrollbar for tactical feeds */\n.custom-scrollbar::-webkit-scrollbar {\n  width: 4px;\n}\n.custom-scrollbar::-webkit-scrollbar-track {\n  background: #050505;\n}\n.custom-scrollbar::-webkit-scrollbar-thumb {\n  background: #ff6600;\n  border-radius: 0px;\n}\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n  background: #ff8533;\n}\n\n/* Diagonal stripe pattern for warnings */\n.diagonal-stripes {\n  background: repeating-linear-gradient(\n    45deg,\n    #ff6600,\n    #ff6600 10px,\n    #050505 10px,\n    #050505 20px\n  );\n}\n\n.diagonal-stripes-purple {\n  background: repeating-linear-gradient(\n    45deg,\n    #9d05ff,\n    #9d05ff 10px,\n    #050505 10px,\n    #050505 20px\n  );\n}\n"
    }
