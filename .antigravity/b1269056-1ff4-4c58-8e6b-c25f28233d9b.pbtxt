    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport { fileURLToPath } from \"url\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI, Type } from \"@google/genai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = path.dirname(__filename);\n\nconst app = express();\nconst PORT = 3000;\n\n// Increase limit for satellite image uploads\napp.use(express.json({ limit: \"20mb\" }));\n\n// Initialize Gemini Client\nconst ai = process.env.GEMINI_API_KEY\n  ? new GoogleGenAI({\n      apiKey: process.env.GEMINI_API_KEY,\n      httpOptions: {\n        headers: {\n          \"User-Agent\": \"aistudio-build\",\n        },\n      },\n    })\n  : null;\n\n// Tokyo Designated Shelters Database (\346\214\207\345\256\232\351\201\277\351\233\243\346\211\200)\n// Coordinates around central Tokyo. \n// Features safety flags for Earthquake (EQ), Tsunami (TS), Flood (FL)\ninterface Shelter {\n  id: string;\n  name: string;\n  name_en: string;\n  lat: number;\n  lng: number;\n  address: string;\n  capacity_max: number;\n  capacity_current: number;\n  hazard_eq: boolean;\n  hazard_ts: boolean;\n  hazard_fl: boolean;\n}\n\nconst SHELTERS: Shelter[] = [\n  {\n    id: \"SHELTER_01_SHIBUYA\",\n    name: \"\346\270\213\350\260\267\343\202\271\343\203\235\343\203\274\343\203\204\343\202\273\343\203\263\343\202\277\343\203\274\",\n    name_en: \"Shibuya Sports Center\",\n    lat: 35.6725,\n    lng: 139.6912,\n    address: \"\346\235\261\344\272\254\351\203\275\346\270\213\350\260\267\345\214\272\350\245\277\345\216\2371-40-1\",\n    capacity_max: 2500,\n    capacity_current: 1800, // 72%\n    hazard_eq: true,\n    hazard_ts: false,\n    hazard_fl: true,\n  },\n  {\n    id: \"SHELTER_02_UENO\",\n    name: \"\344\270\212\351\207\216\346\201\251\350\263\234\345\205\254\345\234\222\351\201\277\351\233\243\346\211\200\",\n    name_en: \"Ueno Park Shelter\",\n    lat: 35.7145,\n    lng: 139.7735,\n    address: \"\346\235\261\344\272\254\351\203\275\345\217\260\346\235\261\345\214\272\344\270\212\351\207\216\345\205\254\345\234\222\",\n    capacity_max: 5000,\n    capacity_current: 4400, // 88%\n    hazard_eq: true,\n    hazard_ts: true,\n    hazard_fl: false,\n  },\n  {\n    id: \"SHELTER_03_MINATO\",\n    name: \"\346\270\257\345\214\272\350\212\235\345\205\254\345\234\222\343\202\260\343\203\251\343\202\246\343\203\263\343\203\211\",\n    name_en: \"Minato Shiba Park Ground\",\n    lat: 35.6558,\n    lng: 139.7482,\n    address: \"\346\235\261\344\272\254\351\203\275\346\270\257\345\214\272\350\212\235\345\205\254\345\234\2224-10-17\",\n    capacity_max: 3000,\n    capacity_current: 2820, // 94%\n    hazard_eq: true,\n    hazard_ts: false,\n    hazard_fl: false,\n  },\n  {\n    id: \"SHELTER_04_SHINJUKU\",\n    name: \"\346\226\260\345\256\277\344\270\255\345\244\256\345\205\254\345\234\222\351\201\277\351\233\243\346\211\200\",\n    name_en: \"Shinjuku Chuo Park\",\n    lat: 35.6896,\n    lng: 139.6917,\n    address: \"\346\235\261\344\272\254\351\203\275\346\226\260\345\256\277\345\214\272\350\245\277\346\226\260\345\256\2772-11\",\n    capacity_max: 4000,\n    capacity_current: 1800, // 45%\n    hazard_eq: true,\n    hazard_ts: true,\n    hazard_fl: true,\n  },\n  {\n    id: \"SHELTER_05_CHIYODA\",\n    name: \"\346\227\245\346\257\224\350\260\267\345\205\254\345\234\222\345\244\247\351\237\263\346\245\275\345\240\202\345\221\250\350\276\272\",\n    name_en: \"Hibiya Park Amphitheater Area\",\n    lat: 35.6738,\n    lng: 139.7558,\n    address: \"\346\235\261\344\272\254\351\203\275\345\215\203\344\273\243\347\224\260\345\214\272\346\227\245\346\257\224\350\260\267\345\205\254\345\234\2221-5\",\n    capacity_max: 3500,\n    capacity_current: 1050, // 30%\n    hazard_eq: true,\n    hazard_ts: false,\n    hazard_fl: true,\n  },\n  {\n    id: \"SHELTER_06_EDOGAWA\",\n    name: \"\346\261\237\346\210\270\345\267\235\345\214\272\351\231\270\344\270\212\347\253\266\346\212\200\345\240\264\",\n    name_en: \"Edogawa Stadium\",\n    lat: 35.6433,\n    lng: 139.8617,\n    address: \"\346\235\261\344\272\254\351\203\275\346\261\237\346\210\270\345\267\235\345\214\272\346\270\205\346\226\260\347\224\2722-1-1\",\n    capacity_max: 4500,\n    capacity_current: 900, // 20%\n    hazard_eq: true,\n    hazard_ts: false,\n    hazard_fl: false, // Low-lying flood area\n  }\n];\n\n// Spatial distance calculator (Haversine formula in KM)\nfunction calculateDistance(lat1: number, lon1: number, lat2: number, lon2: number) {\n  const R = 6371; // Earth\'s radius in km\n  const dLat = (lat2 - lat1) * Math.PI / 180;\n  const dLon = (lon2 - lon1) * Math.PI / 180;\n  const a =\n    Math.sin(dLat / 2) * Math.sin(dLat / 2) +\n    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *\n    Math.sin(dLon / 2) * Math.sin(dLon / 2);\n  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n  return parseFloat((R * c).toFixed(2));\n}\n\n// Global active event state for mock/simulated disasters\nlet activeSimulatedDisaster: any = null;\n\n// Store SSE connections to stream updates to the front-end\nlet sseClients: any[] = [];\n\n// Broadcast SSE event\nfunction broadcastSSE(type: string, data: any) {\n  sseClients.forEach((client) => {\n    client.write(`event: ${type}\\n`);\n    client.write(`data: ${JSON.stringify(data)}\\n\\n`);\n  });\n}\n\n// REST API Endpoints\n\n// 1. Shelter Database spatial search\napp.get(\"/api/shelters\", (req, res) => {\n  const lat = parseFloat(req.query.lat as string) || 35.6895;\n  const lng = parseFloat(req.query.lng as string) || 139.6917;\n  const hazard = (req.query.hazard as string) || \"earthquake\";\n\n  // Calculate distances\n  const result = SHELTERS.map((s) => {\n    const distance = calculateDistance(lat, lng, s.lat, s.lng);\n    let is_safe = true;\n    if (hazard === \"earthquake\") is_safe = s.hazard_eq;\n    else if (hazard === \"tsunami\") is_safe = s.hazard_ts;\n    else if (hazard === \"flood\" || hazard === \"landslide\" || hazard === \"typhoon\") is_safe = s.hazard_fl;\n\n    return {\n      ...s,\n      distance_km: distance,\n      is_safe,\n    };\n  });\n\n  // Sort by distance\n  result.sort((a, b) => a.distance_km - b.distance_km);\n\n  res.json(result);\n});\n\n// 2. Fetch live JMA alerts from p2pquake historical feed\napp.get(\"/api/earthquakes\", async (req, res) => {\n  try {\n    // p2pquake public API for history. code 551 is earthquake info\n    const response = await fetch(\"https://api.p2pquake.net/v2/history?codes=551&limit=5\");\n    if (!response.ok) {\n      throw new Error(\"Failed to fetch from p2pquake\");\n    }\n    const data = await response.json();\n    res.json(data);\n  } catch (error: any) {\n    // Fallback Mock Data if p2pquake is down or rate limited\n    res.json([\n      {\n        id: \"mock_eq_1\",\n        time: new Date().toISOString(),\n        earthquake: {\n          hypocenter: { name: \"Sagami Bay (\347\233\270\346\250\241\346\271\276)\", depth: 10, latitude: 35.2, longitude: 139.3 },\n          maxScale: 40, // Shindo 4\n          domesticTsunami: \"None\",\n        },\n      },\n    ]);\n  }\n});\n\n// 3. Simulated Intel broadcast feeds (mcp-twitter/NERV style alerts)\nconst defaultIntelFeed = [\n  {\n    id: \"intel_1\",\n    time: \"14:02:11\",\n    tag: \"FLASH\",\n    text: \"JMA reports minor tremors in Sagami Bay. Tsunami sensors stabilizing.\",\n  },\n  {\n    id: \"intel_2\",\n    time: \"14:00:45\",\n    tag: \"NERV\",\n    text: \"Sector 4 shelter capacity reaching 85%. Traffic control rerouting to Sector 7.\",\n  },\n  {\n    id: \"intel_3\",\n    time: \"13:58:22\",\n    tag: \"STABLE\",\n    text: \"Power grid frequency fluctuation detected in Chiyoda-ku. No outage expected.\",\n  },\n  {\n    id: \"intel_4\",\n    time: \"13:55:10\",\n    tag: \"URGENT\",\n    text: \"Anomalous thermal signature detected at Shinjuku crossing point. Analyzing.\",\n  },\n];\n\napp.get(\"/api/intel\", (req, res) => {\n  res.json(defaultIntelFeed);\n});\n\n// 4. Trigger simulated disaster\napp.post(\"/api/simulate/earthquake\", async (req, res) => {\n  const { magnitude, epicenterName, lat, lng } = req.body;\n  \n  const timestamp = new Date().toLocaleTimeString(\"ja-JP\", { hour12: false });\n  \n  const newDisaster = {\n    disaster_type: \"earthquake\",\n    intensity_max: magnitude >= 7 ? \"7\" : \"6-\345\274\272\",\n    epicenter: epicenterName || \"Tokyo Bay (\346\235\261\344\272\254\346\271\276)\",\n    lat: lat || 35.60,\n    lng: lng || 139.80,\n    affected_prefectures: [\"Tokyo\", \"Kanagawa\", \"Chiba\", \"Saitama\"],\n    immediate_hazards: [\n      \"Severe ground shaking in coastal reclaim blocks\",\n      \"Minor sea level fluctuations detected\",\n      \"Liquefaction vulnerability in Koto-ku\",\n    ],\n    agent_triage_directives: [\n      \">> RED ALERT: Deploy Emergency Taskforce to Tokyo Port District\",\n      \">> CRITICAL: Divert traffic away from Rainbow Bridge\",\n      \">> WARNING: High capacity load on Shinjuku Sector 4 shelter\",\n    ],\n    drafts: {\n      sms_alert_jp: `\343\200\220\347\267\212\346\200\245\345\234\260\351\234\207\351\200\237\345\240\261\343\200\221${epicenterName || \'\346\235\261\344\272\254\346\271\276\'}\343\201\247\345\244\247\345\234\260\351\234\207\347\231\272\347\224\237\343\200\202\345\274\267\343\201\204\346\217\272\343\202\214\343\201\253\350\255\246\346\210\222\343\200\201\350\272\253\343\201\256\345\256\211\345\205\250\343\202\222\347\242\272\344\277\235\343\201\227\343\201\246\343\201\217\343\201\240\343\201\225\343\201\204\343\200\202`,\n      sms_alert_en: `EMERGENCY ALERT: Major Earthquake off ${epicenterName || \'Tokyo Bay\'}. Drop, Cover, and Hold on.`,\n      social_feed_jp: `\343\200\220NERV\347\201\275\345\256\263\345\257\276\347\255\226\346\234\254\351\203\250\343\200\221\346\235\261\344\272\254\346\271\276\343\202\222\351\234\207\346\272\220\343\201\250\343\201\231\343\202\213\343\203\236\343\202\260\343\203\213\343\203\201\343\203\245\343\203\274\343\203\2117.2\343\201\256\345\234\260\351\234\207\343\202\222\350\246\263\346\270\254\343\200\202\346\234\200\345\244\247\351\234\207\345\272\2467\343\200\202\346\264\245\346\263\242\350\255\246\345\240\261\343\201\256\346\234\211\347\204\241\343\201\253\350\255\246\346\210\222\343\201\233\343\202\210\343\200\202\351\201\277\351\233\243\347\265\214\350\267\257\343\202\222\347\242\272\344\277\235\343\200\202 #\351\230\262\347\201\275`,\n    },\n    timestamp,\n  };\n\n  activeSimulatedDisaster = newDisaster;\n  \n  // Add an entry in SSE Intel Feed\n  const feedEvent = {\n    id: `intel_${Date.now()}`,\n    time: timestamp,\n    tag: \"CRITICAL\",\n    text: `SIMULATION TRIGGERED: Magnitude ${magnitude} Earthquake detected at ${epicenterName || \'Tokyo Bay\'}. Shindo ${magnitude >= 7 ? \'7\' : \'6+\'}.`,\n  };\n\n  broadcastSSE(\"disaster_alert\", newDisaster);\n  broadcastSSE(\"intel_feed\", feedEvent);\n\n  res.json({ success: true, disaster: newDisaster, feedEvent });\n});\n\n// 5. Gemini 3.5 Flash Triage Engine\n// Generates critical multi-agent triage logs, broadcaster warnings, and coordinates.\n// Supports uploading actual photos (Satellite Base64 strings or logs)\napp.post(\"/api/triage\", async (req, res) => {\n  if (!ai) {\n    return res.status(500).json({\n      error: \"Gemini API key is not configured. Please add GEMINI_API_KEY to your secrets.\",\n    });\n  }\n\n  const { prompt, imageBase64, imageMime } = req.body;\n\n  try {\n    const sysInstruction = `You are the intelligence core of the NERV Disaster Response Coordinator. Your purpose is to process highly chaotic, multimodal data (JMA alert JSON, satellite images, local tweets) and coordinate immediate evacuation and resource allocation recommendations for Japan.\n\nWhen processing, follow these rules strictly:\n1. Always parse location text (e.g., \"\346\226\260\345\256\277\345\214\272\", \"Shinjuku\", \"\346\235\261\344\272\254\346\271\276\") and associate it with geographic regions.\n2. For any disaster, cross-reference designated shelters (\351\201\277\351\233\243\346\211\200) based on the threat vector. DO NOT recommend a shelter flagged as unsafe for the active hazard.\n3. Always output your findings and coordinated outputs in highly structured JSON formats.\n4. Keep translations accurate across Japanese (\346\227\245\346\234\254\350\252\236) and English.`;\n\n    const responseSchema = {\n      type: Type.OBJECT,\n      properties: {\n        disaster_type: { \n          type: Type.STRING, \n          enum: [\"earthquake\", \"tsunami\", \"flood\", \"typhoon\", \"landslide\", \"other\"] \n        },\n        intensity_max: { \n          type: Type.STRING, \n          description: \"JMA Shindo scale (1 to 7)\" \n        },\n        epicenter: { type: Type.STRING },\n        affected_prefectures: {\n          type: Type.ARRAY,\n          items: { type: Type.STRING }\n        },\n        immediate_hazards: {\n          type: Type.ARRAY,\n          items: { type: Type.STRING }\n        },\n        agent_triage_directives: {\n          type: Type.ARRAY,\n          items: { type: Type.STRING }\n        },\n        drafts: {\n          type: Type.OBJECT,\n          properties: {\n            sms_alert_jp: { type: Type.STRING },\n            sms_alert_en: { type: Type.STRING },\n            social_feed_jp: { type: Type.STRING }\n          },\n          required: [\"sms_alert_jp\", \"sms_alert_en\", \"social_feed_jp\"]\n        }\n      },\n      required: [\n        \"disaster_type\", \n        \"intensity_max\", \n        \"epicenter\", \n        \"affected_prefectures\", \n        \"immediate_hazards\", \n        \"agent_triage_directives\", \n        \"drafts\"\n      ]\n    };\n\n    let contents: any[] = [];\n    if (imageBase64 && imageMime) {\n      contents.push({\n        inlineData: {\n          mimeType: imageMime,\n          data: imageBase64,\n        },\n      });\n    }\n\n    contents.push({\n      text: prompt || \"Assess current tactical situation and provide immediate triage response directives for Tokyo Bay area.\",\n    });\n\n    const response = await ai.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents,\n      config: {\n        systemInstruction: sysInstruction,\n        responseMimeType: \"application/json\",\n        responseSchema: responseSchema,\n      },\n    });\n\n    const resultText = response.text || \"{}\";\n    const triageResult = JSON.parse(resultText);\n\n    // Update active simulation with this triage output\n    activeSimulatedDisaster = {\n      ...triageResult,\n      timestamp: new Date().toLocaleTimeString(\"ja-JP\", { hour12: false }),\n    };\n\n    broadcastSSE(\"disaster_alert\", activeSimulatedDisaster);\n\n    res.json(triageResult);\n  } catch (error: any) {\n    console.error(\"Gemini triage error:\", error);\n    res.status(500).json({ error: error.message || \"Failed to process triage via Gemini API\" });\n  }\n});\n\n// 6. SSE Event Stream Endpoint for Real-time Dashboard Updating\napp.get(\"/api/stream\", (req, res) => {\n  res.setHeader(\"Content-Type\", \"text/event-stream\");\n  res.setHeader(\"Cache-Control\", \"no-cache\");\n  res.setHeader(\"Connection\", \"keep-alive\");\n  res.setHeader(\"Access-Control-Allow-Origin\", \"*\");\n\n  // Send initial handshake\n  res.write(\"data: { \\\"connected\\\": true }\\n\\n\");\n\n  sseClients.push(res);\n\n  // Remove connection when client disconnects\n  req.on(\"close\", () => {\n    sseClients = sseClients.filter((client) => client !== res);\n  });\n});\n\n// Serve frontend assets\nif (process.env.NODE_ENV !== \"production\") {\n  const vite = await createViteServer({\n    server: { middlewareMode: true },\n    appType: \"spa\",\n  });\n  app.use(vite.middlewares);\n} else {\n  const distPath = path.join(process.cwd(), \"dist\");\n  app.use(express.static(distPath));\n  app.get(\"*\", (req, res) => {\n    res.sendFile(path.join(distPath, \"index.html\"));\n  });\n}\n\napp.listen(PORT, \"0.0.0.0\", () => {\n  console.log(`NERV Geospatial Command Center backend running on port ${PORT}`);\n});\n"
    }
