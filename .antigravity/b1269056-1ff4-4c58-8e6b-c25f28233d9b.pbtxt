  }
  file_change {
    absolute_path_uri: "file:///src/components/TacticalMap.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \"react\";\nimport { Shelter, DisasterAlert } from \"../types\";\nimport { Compass, ZoomIn, ZoomOut, Eye, Layers, ShieldAlert, Navigation } from \"lucide-react\";\n\ninterface TacticalMapProps {\n  shelters: Shelter[];\n  activeAlert: DisasterAlert | null;\n  selectedShelterId: string | null;\n  onSelectShelter: (id: string) => void;\n  satelliteImage: string | null;\n}\n\nexport default function TacticalMap({\n  shelters,\n  activeAlert,\n  selectedShelterId,\n  onSelectShelter,\n  satelliteImage,\n}: TacticalMapProps) {\n  const [zoomLevel, setZoomLevel] = useState<\"1:25,000\" | \"1:50,000\" | \"1:100,000\">(\"1:25,000\");\n  const [showGrids, setShowGrids] = useState(true);\n  const [showRoutes, setShowRoutes] = useState(true);\n  const [showSensors, setShowSensors] = useState(true);\n  const [waveRadius, setWaveRadius] = useState(0);\n\n  // Projection engine mapping Tokyo coordinates onto an 800x600 SVG viewBox\n  function project(lat: number, lng: number) {\n    const minLat = 35.58;\n    const maxLat = 35.76;\n    const minLng = 139.62;\n    const maxLng = 139.92;\n\n    const x = ((lng - minLng) / (maxLng - minLng)) * 700 + 50;\n    // y is inverted in SVG\n    const y = 550 - ((lat - minLat) / (maxLat - minLat)) * 500;\n    return { x, y };\n  }\n\n  // Animating epicenter seismic waves\n  useEffect(() => {\n    if (activeAlert) {\n      setWaveRadius(0);\n      const interval = setInterval(() => {\n        setWaveRadius((prev) => (prev >= 120 ? 0 : prev + 1.5));\n      }, 30);\n      return () => clearInterval(interval);\n    }\n  }, [activeAlert]);\n\n  // Coordinates of coastlines & major landmarks to draw a high-fidelity vector Tokyo Bay outline\n  const coastalPath = `\n    M 50,550 \n    Q 120,480 200,450 \n    T 320,380 \n    Q 410,400 440,430 \n    T 500,480 \n    Q 550,510 580,480 \n    T 620,400 \n    Q 680,380 750,420\n    L 750,550\n    Z\n  `;\n\n  // Major rivers / canals in Tokyo (Sumida, Arakawa, Edo)\n  const rivers = [\n    // Sumida River\n    \"M 380,50 Q 360,180 410,250 T 450,410\",\n    // Arakawa River\n    \"M 550,50 Q 510,180 540,280 T 570,412\",\n    // Edo River\n    \"M 710,50 Q 660,150 680,260 T 730,370\"\n  ];\n\n  // Grid line values\n  const gridLinesX = Array.from({ length: 7 }, (_, i) => 100 + i * 100);\n  const gridLinesY = Array.from({ length: 5 }, (_, i) => 100 + i * 100);\n\n  // Epicenter coordinates\n  const epicenterCoords = activeAlert?.lat && activeAlert?.lng\n    ? project(activeAlert.lat, activeAlert.lng)\n    : project(35.60, 139.80); // Default Tokyo Bay epicenter\n\n  // Find projected coords for selected shelter to draw evacuation routing lines\n  const focusedShelter = shelters.find(s => s.id === selectedShelterId);\n  const selectedShelterCoords = focusedShelter\n    ? project(focusedShelter.lat, focusedShelter.lng)\n    : null;\n\n  return (\n    <div className=\"border border-[#393939] bg-[#121212] relative overflow-hidden h-full flex flex-col font-mono\">\n      {/* Map Header Panel */}\n      <div className=\"flex items-center justify-between px-3 py-2 border-b border-[#393939] bg-[#0c0c0c] text-xs\">\n        <div className=\"flex items-center gap-2 text-white\">\n          <Compass className=\"w-4 h-4 text-[#ff6600] animate-spin-slow\" />\n          <span className=\"font-bold tracking-wider\">TACTICAL_MAP_VIEW :: TOKYO_BAY</span>\n        </div>\n        <div className=\"flex items-center gap-4 text-[10px] text-gray-400\">\n          <div>ZOOM_LVL: <span className=\"text-[#ff6600]\">{zoomLevel}</span></div>\n          <div>PROJECTION: <span className=\"text-gray-200\">UTM_54N</span></div>\n        </div>\n      </div>\n\n      {/* Vector Interactive Map Area */}\n      <div className=\"relative flex-1 bg-[#050505] overflow-hidden select-none\">\n        {/* Decorative Grid Mesh */}\n        <div className=\"absolute inset-0 nerv-grid-bg pointer-events-none opacity-40\"></div>\n\n        {/* Real Dynamic Satellite Scan Overlay */}\n        {satelliteImage && (\n          <div className=\"absolute inset-0 pointer-events-none z-10 opacity-30 mix-blend-screen transition-opacity\">\n            <img \n              src={satelliteImage} \n              alt=\"Satellite Scan\" \n              className=\"w-full h-full object-cover filter brightness-125 contrast-125 grayscale hue-rotate-15\"\n              referrerPolicy=\"no-referrer\"\n            />\n            {/* Blinking Classification overlay */}\n            <div className=\"absolute top-4 left-4 bg-black/80 border border-[#9d05ff] px-2 py-1 text-[9px] text-[#9d05ff] font-bold tracking-widest uppercase animate-pulse\">\n              [SATELLITE THERMAL SCAN ACTIVE]\n            </div>\n          </div>\n        )}\n\n        <svg \n          viewBox=\"0 0 800 600\" \n          className=\"w-full h-full text-[#2a2a2a] relative z-0\"\n        >\n          {/* 1. Styled Tokyo Bay Contour */}\n          <path\n            d={coastalPath}\n            fill=\"#090909\"\n            stroke=\"#201f1f\"\n            strokeWidth=\"1.5\"\n            className=\"transition-colors\"\n          />\n\n          {/* 2. Rivers */}\n          {rivers.map((r, i) => (\n            <path\n              key={i}\n              d={r}\n              fill=\"none\"\n              stroke=\"#131313\"\n              strokeWidth=\"2.5\"\n            />\n          ))}\n\n          {/* 3. Grid coordinates & lines */}\n          {showGrids && (\n            <g className=\"opacity-30 pointer-events-none\">\n              {gridLinesX.map((xVal, idx) => (\n                <g key={`x-${idx}`}>\n                  <line \n                    x1={xVal} y1=\"0\" x2={xVal} y2=\"600\" \n                    stroke=\"#353534\" strokeWidth=\"0.5\" strokeDasharray=\"2,5\" \n                  />\n                  <text \n                    x={xVal + 5} y=\"15\" \n                    fill=\"#aa8a7d\" fontSize=\"9\" className=\"font-mono\"\n                  >\n                    139.{(62 + idx * 0.05).toFixed(2)}E\n                  </text>\n                </g>\n              ))}\n              {gridLinesY.map((yVal, idx) => (\n                <g key={`y-${idx}`}>\n                  <line \n                    x1=\"0\" y1={yVal} x2=\"800\" y2={yVal} \n                    stroke=\"#353534\" strokeWidth=\"0.5\" strokeDasharray=\"2,5\" \n                  />\n                  <text \n                    x=\"5\" y={yVal - 5} \n                    fill=\"#aa8a7d\" fontSize=\"9\" className=\"font-mono\"\n                  >\n                    35.{(58 + idx * 0.04).toFixed(2)}N\n                  </text>\n                </g>\n              ))}\n            </g>\n          )}\n\n          {/* 4. Seismic Sensors Array Markers */}\n          {showSensors && (\n            <g className=\"opacity-20\">\n              {/* Plot general military/geospatial sensor triangles */}\n              <polygon points=\"120,100 125,110 115,110\" fill=\"#00FF66\" />\n              <polygon points=\"500,120 505,130 495,130\" fill=\"#00FF66\" />\n              <polygon points=\"210,320 215,330 205,330\" fill=\"#00FF66\" />\n              <polygon points=\"680,210 685,220 675,220\" fill=\"#00FF66\" />\n              <polygon points=\"410,480 415,490 405,490\" fill=\"#00FF66\" />\n            </g>\n          )}\n\n          {/* 5. active epicenters & seismic shockwaves */}\n          {activeAlert && (\n            <g>\n              {/* Concentric seismic waves radiating */}\n              <circle\n                cx={epicenterCoords.x}\n                cy={epicenterCoords.y}\n                r={waveRadius}\n                fill=\"none\"\n                stroke={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                strokeWidth=\"1.5\"\n                opacity={Math.max(0, 1 - waveRadius / 120)}\n                pointerEvents=\"none\"\n              />\n              <circle\n                cx={epicenterCoords.x}\n                cy={epicenterCoords.y}\n                r={Math.max(0, waveRadius - 40)}\n                fill=\"none\"\n                stroke={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                strokeWidth=\"1.2\"\n                opacity={Math.max(0, 1 - (waveRadius - 40) / 120)}\n                pointerEvents=\"none\"\n              />\n              <circle\n                cx={epicenterCoords.x}\n                cy={epicenterCoords.y}\n                r={Math.max(0, waveRadius - 80)}\n                fill=\"none\"\n                stroke={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                strokeWidth=\"0.8\"\n                opacity={Math.max(0, 1 - (waveRadius - 80) / 120)}\n                pointerEvents=\"none\"\n              />\n\n              {/* Pulsating Epicenter diamond indicator */}\n              <g className=\"cursor-pointer\">\n                <rect\n                  x={epicenterCoords.x - 8}\n                  y={epicenterCoords.y - 8}\n                  width=\"16\"\n                  height=\"16\"\n                  transform={`rotate(45, ${epicenterCoords.x}, ${epicenterCoords.y})`}\n                  fill={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                  className=\"animate-pulse\"\n                />\n                <circle\n                  cx={epicenterCoords.x}\n                  cy={epicenterCoords.y}\n                  r=\"14\"\n                  fill=\"none\"\n                  stroke={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                  strokeWidth=\"1\"\n                  className=\"animate-ping\"\n                />\n                {/* Text tag label */}\n                <rect \n                  x={epicenterCoords.x + 15} \n                  y={epicenterCoords.y - 12} \n                  width=\"110\" \n                  height=\"22\" \n                  fill=\"#050505\" \n                  stroke={activeAlert.intensity_max === \"7\" ? \"#9d05ff\" : \"#ff6600\"}\n                  strokeWidth=\"1\" \n                />\n                <text \n                  x={epicenterCoords.x + 20} \n                  y={epicenterCoords.y + 3} \n                  fill=\"#e5e2e1\" \n                  fontSize=\"8\" \n                  fontWeight=\"bold\"\n                >\n                  EPICENTER :: M{activeAlert.intensity_max === \"7\" ? \"7.2\" : \"6.5\"}\n                </text>\n              </g>\n            </g>\n          )}\n\n          {/* 6. Shelter Nodes */}\n          {shelters.map((shelter) => {\n            const coords = project(shelter.lat, shelter.lng);\n            const isSelected = shelter.id === selectedShelterId;\n            const isCritical = shelter.capacity_current / shelter.capacity_max >= 0.9;\n            const isWarning = shelter.capacity_current / shelter.capacity_max >= 0.75 && !isCritical;\n            \n            // Determine shelter node styling based on NERV specifications (Orange for warning, Purple for critical, green for stable)\n            let glowClass = \"stroke-[#00e55b] fill-[#00e55b]\";\n            if (isCritical) glowClass = \"stroke-[#9d05ff] fill-[#9d05ff]\";\n            else if (isWarning) glowClass = \"stroke-[#ff6600] fill-[#ff6600]\";\n\n            return (\n              <g \n                key={shelter.id}\n                className=\"cursor-pointer group\"\n                onClick={() => onSelectShelter(shelter.id)}\n              >\n                {/* Visual glow indicator */}\n                {isSelected && (\n                  <circle\n                    cx={coords.x}\n                    cy={coords.y}\n                    r=\"15\"\n                    fill=\"none\"\n                    stroke={isCritical ? \"#9d05ff\" : isWarning ? \"#ff6600\" : \"#00FF66\"}\n                    strokeWidth=\"1.5\"\n                    className=\"animate-ping opacity-60\"\n                  />\n                )}\n\n                {/* Node circle */}\n                <circle\n                  cx={coords.x}\n                  cy={coords.y}\n                  r={isSelected ? \"7\" : \"5\"}\n                  className={`transition-all duration-300 ${glowClass} stroke-2`}\n                  fillOpacity={isSelected ? \"1\" : \"0.3\"}\n                />\n\n                {/* Micro text label */}\n                <text\n                  x={coords.x + 10}\n                  y={coords.y + 3}\n                  fill={isSelected ? \"#ffffff\" : \"#aa8a7d\"}\n                  fontSize={isSelected ? \"10\" : \"8\"}\n                  fontWeight={isSelected ? \"bold\" : \"normal\"}\n                  className=\"pointer-events-none drop-shadow-md select-none font-mono\"\n                >\n                  {shelter.name_en.toUpperCase()}\n                </text>\n              </g>\n            );\n          })}\n\n          {/* 7. Evacuation routes connecting Epicenter to selected Shelter */}\n          {showRoutes && selectedShelterCoords && activeAlert && (\n            <g>\n              <line\n                x1={epicenterCoords.x}\n                y1={epicenterCoords.y}\n                x2={selectedShelterCoords.x}\n                y2={selectedShelterCoords.y}\n                stroke=\"#9d05ff\"\n                strokeWidth=\"1.5\"\n                strokeDasharray=\"4,6\"\n                className=\"animate-pulse\"\n                opacity=\"0.8\"\n              />\n              <circle cx={selectedShelterCoords.x} cy={selectedShelterCoords.y} r=\"18\" fill=\"none\" stroke=\"#9d05ff\" strokeWidth=\"1\" strokeDasharray=\"2,2\" />\n              \n              {/* Route distance indicator tag */}\n              <rect\n                x={(epicenterCoords.x + selectedShelterCoords.x) / 2 - 35}\n                y={(epicenterCoords.y + selectedShelterCoords.y) / 2 - 10}\n                width=\"70\"\n                height=\"16\"\n                fill=\"#0e0e0e\"\n                stroke=\"#393939\"\n                strokeWidth=\"1\"\n              />\n              <text\n                x={(epicenterCoords.x + selectedShelterCoords.x) / 2}\n                y={(epicenterCoords.y + selectedShelterCoords.y) / 2 + 1}\n                fill=\"#e5e2e1\"\n                fontSize=\"7\"\n                textAnchor=\"middle\"\n                fontWeight=\"bold\"\n              >\n                EVAC_ROUTE\n              </text>\n            </g>\n          )}\n        </svg>\n\n        {/* Selected Shelter Reticle & Information Overlay (floating box bottom-right of map) */}\n        {focusedShelter && selectedShelterCoords && (\n          <div className=\"absolute top-12 right-4 bg-black/95 border-2 border-[#393939] text-[#e5e2e1] p-3 w-56 text-[10px] space-y-1.5 z-20 glow-orange\">\n            <div className=\"flex items-center justify-between border-b border-[#393939] pb-1\">\n              <span className=\"text-[#ff6600] font-bold tracking-wider\">[SELECTED NODE]</span>\n              <span className=\"text-gray-400\">ID: {focusedShelter.id.split(\"_\")[2]}</span>\n            </div>\n            <div className=\"text-sm font-bold text-white uppercase\">{focusedShelter.name}</div>\n            <div className=\"text-gray-400 italic\">{focusedShelter.name_en}</div>\n            <div className=\"border-t border-[#1c1b1b] pt-1.5 space-y-1\">\n              <div className=\"flex justify-between\">\n                <span>LAT / LNG:</span>\n                <span className=\"text-[#00FF66]\">{focusedShelter.lat.toFixed(4)} / {focusedShelter.lng.toFixed(4)}</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span>EST DISTANCE:</span>\n                <span className=\"text-[#ff6600] font-bold\">\n                  {focusedShelter.distance_km ? `${focusedShelter.distance_km} KM` : \"CALCULATING\"}\n                </span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span>SAFE STATUS:</span>\n                <span className={focusedShelter.is_safe !== false ? \"text-[#00FF66] font-bold\" : \"text-[#9d05ff] font-bold\"}>\n                  {focusedShelter.is_safe !== false ? \"\342\227\217 SECURE\" : \"\342\226\262 UNSAFE FOR VECTOR\"}\n                </span>\n              </div>\n            </div>\n            <div className=\"pt-1 flex items-center gap-1\">\n              <Navigation className=\"w-3 h-3 text-[#ff6600] animate-bounce\" />\n              <span className=\"text-[8px] text-[#ff6600]\">SECURE ROUTE DRAWN ON TACTICAL RADAR</span>\n            </div>\n          </div>\n        )}\n\n        {/* Map Grid / Layer Controls Bar */}\n        <div className=\"absolute bottom-4 left-4 bg-[#0c0c0c]/90 border border-[#393939] px-3 py-1.5 flex gap-4 text-[10px] text-gray-300 z-20\">\n          <label className=\"flex items-center gap-1.5 cursor-pointer hover:text-white\">\n            <input \n              type=\"checkbox\" \n              checked={showGrids} \n              onChange={() => setShowGrids(!showGrids)}\n              className=\"accent-[#ff6600] rounded-none bg-black border-[#393939]\" \n            />\n            <span>COORD_GRIDS</span>\n          </label>\n          <label className=\"flex items-center gap-1.5 cursor-pointer hover:text-white\">\n            <input \n              type=\"checkbox\" \n              checked={showRoutes} \n              onChange={() => setShowRoutes(!showRoutes)}\n              className=\"accent-[#ff6600] rounded-none bg-black border-[#393939]\" \n            />\n            <span>EVAC_VECTOR</span>\n          </label>\n          <label className=\"flex items-center gap-1.5 cursor-pointer hover:text-white\">\n            <input \n              type=\"checkbox\" \n              checked={showSensors} \n              onChange={() => setShowSensors(!showSensors)}\n              className=\"accent-[#ff6600] rounded-none bg-black border-[#393939]\" \n            />\n            <span>SENSORS</span>\n          </label>\n        </div>\n\n        {/* Mini compass overlay on map */}\n        <div className=\"absolute bottom-4 right-4 text-gray-500 flex flex-col items-center select-none pointer-events-none opacity-40\">\n          <Compass className=\"w-8 h-8 text-[#ff6600]\" />\n          <span className=\"text-[8px] mt-1\">ORIENT::N</span>\n        </div>\n      </div>\n\n      {/* Map Control Actions Footer */}\n      <div className=\"flex items-center gap-3 p-2 bg-[#0c0c0c] border-t border-[#393939] text-xs\">\n        <div className=\"text-gray-400\">RADAR COMMANDS:</div>\n        <button \n          onClick={() => setZoomLevel(\"1:25,000\")} \n          className={`px-2 py-0.5 border ${zoomLevel === \"1:25,000\" ? \"bg-[#ff6600]/20 text-[#ff6600] border-[#ff6600]\" : \"border-[#393939] text-gray-400 hover:text-white\"}`}\n        >\n          25K\n        </button>\n        <button \n          onClick={() => setZoomLevel(\"1:50,000\")} \n          className={`px-2 py-0.5 border ${zoomLevel === \"1:50,000\" ? \"bg-[#ff6600]/20 text-[#ff6600] border-[#ff6600]\" : \"border-[#393939] text-gray-400 hover:text-white\"}`}\n        >\n          50K\n        </button>\n        <button \n          onClick={() => setZoomLevel(\"1:100,000\")} \n          className={`px-2 py-0.5 border ${zoomLevel === \"1:100,000\" ? \"bg-[#ff6600]/20 text-[#ff6600] border-[#ff6600]\" : \"border-[#393939] text-gray-400 hover:text-white\"}`}\n        >\n          100K\n        </button>\n      </div>\n    </div>\n  );\n}\n"
    }
