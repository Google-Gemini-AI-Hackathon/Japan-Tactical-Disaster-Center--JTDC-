        }
        lines {
          text: "          {/* 8. Shelter Nodes (Designated Safe zones) */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          {shelters.map((shelter) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const coords = project(shelter.lat, shelter.lng);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isSelected = shelter.id === selectedShelterId;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isCritical = shelter.capacity_current / shelter.capacity_max >= 0.9;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isWarning = shelter.capacity_current / shelter.capacity_max >= 0.75 && !isCritical;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            // Determine shelter node styling based on NERV specifications (Orange for warning, Purple for critical, green for stable)"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            let glowClass = \"stroke-[#00e55b] fill-[#00e55b]\";"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            if (isCritical) glowClass = \"stroke-[#9d05ff] fill-[#9d05ff]\";"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            else if (isWarning) glowClass = \"stroke-[#ff6600] fill-[#ff6600]\";"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "            // Render styled shelter circles matching specs"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            let nodeFillColor = \"#00FF66\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            if (isCritical) nodeFillColor = \"#9d05ff\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "            else if (isWarning) nodeFillColor = \"#ff6600\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            return ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <g "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                key={shelter.id}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                className=\"cursor-pointer group\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                onClick={() => onSelectShelter(shelter.id)}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              >"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                {/* Visual glow indicator */}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                {/* Visual glowing ring for selection */}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                {isSelected && ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  <circle"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    cx={coords.x}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    cy={coords.y}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    r=\"15\""
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                    r=\"16\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                    fill=\"none\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    stroke={isCritical ? \"#9d05ff\" : isWarning ? \"#ff6600\" : \"#00FF66\"}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                    strokeWidth=\"1.5\""
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                    className=\"animate-ping opacity-60\""
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
