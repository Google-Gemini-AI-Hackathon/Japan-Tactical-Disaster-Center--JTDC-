        lines {
          text: "// Spatial distance calculator (Haversine formula in KM)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function calculateDistance(lat1: number, lon1: number, lat2: number, lon2: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const R = 6371; // Earth\'s radius in km"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const dLat = (lat2 - lat1) * Math.PI / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const dLon = (lon2 - lon1) * Math.PI / 180;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const a ="
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(dLat / 2) * Math.sin(dLat / 2) +"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    Math.sin(dLon / 2) * Math.sin(dLon / 2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return parseFloat((R * c).toFixed(2));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
