        lines {
          text: "            const coords = project(shelter.lat, shelter.lng);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isSelected = shelter.id === selectedShelterId;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isCritical = shelter.capacity_current / shelter.capacity_max >= 0.9;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            const isWarning = shelter.capacity_current / shelter.capacity_max >= 0.75 && !isCritical;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            // Render styled shelter circles matching specs"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            let nodeFillColor = \"#00FF66\";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            if (isCritical) nodeFillColor = \"#9d05ff\";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "            else if (isWarning) nodeFillColor = \"#ff6600\";"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
